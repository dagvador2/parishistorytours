---
import { Picture } from "astro:assets";
import { useTranslations } from '../i18n/utils';

import pantheon     from "../images/pantheon_de_Paris.webp";
import placeVendome from "../images/place_vendome_paris.webp";
import ileDeLaCite  from "../images/ile_de_la_cite_paris.webp";

const lang = Astro.locals.lang;
const t = useTranslations(lang);
const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';

const tours = [
	{ href: `${langPrefix}/tours/left-bank`, src: pantheon, alt: t('tours.leftBank.title'), label: t('booking.leftBank') },
	{ href: `${langPrefix}/tours/right-bank`, src: placeVendome, alt: t('tours.rightBank.title'), label: t('booking.rightBank') },
	{ href: `${langPrefix}/tours/general-history`, src: ileDeLaCite, alt: t('tours.generalHistory.title'), label: t('booking.generalHistory') },
];
---

{/* Section – Tours available */}
<div id="tours" class="mb-16">
	<h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-gray-800">
		{t('tours.title')}
	</h2>
	<p class="text-center text-gray-600 mb-12 text-lg">
		{t('tours.subtitle')}
	</p>

	{/* Desktop: 3 columns */}
	<div class="hidden md:flex gap-8 justify-center items-center max-w-6xl mx-auto px-4">
		{tours.map(tour => (
			<a href={tour.href}
			   class="group block w-1/3 max-w-lg rounded-xl overflow-hidden shadow-lg transition-transform duration-300 hover:scale-105">
				<div class="relative">
					<Picture
						src={tour.src}
						alt={tour.alt}
						widths={[480,640,768,1024]}
						sizes="33vw"
						formats={["avif","webp"]}
						loading="lazy"
						decoding="async"
						quality={70}
						class="w-full h-72 object-cover"
					/>
					<div class="absolute inset-0 bg-black/30 flex items-center justify-center">
						<span class="text-white text-3xl md:text-4xl font-bold tracking-wider drop-shadow-lg text-center px-4">
							{tour.label}
						</span>
					</div>
				</div>
			</a>
		))}
	</div>

	{/* Mobile: swipeable slider */}
	<div class="md:hidden tours-slider relative overflow-hidden mx-4">
		<div class="tours-track flex transition-transform duration-400 ease-out">
			{tours.map(tour => (
				<a href={tour.href}
				   class="tours-slide shrink-0 w-full px-2">
					<div class="rounded-xl overflow-hidden shadow-lg">
						<div class="relative">
							<Picture
								src={tour.src}
								alt={tour.alt}
								widths={[375,480,640]}
								sizes="100vw"
								formats={["avif","webp"]}
								loading="lazy"
								decoding="async"
								quality={70}
								class="w-full h-64 object-cover"
							/>
							<div class="absolute inset-0 bg-black/30 flex items-center justify-center">
								<span class="text-white text-3xl font-bold tracking-wider drop-shadow-lg text-center px-4">
									{tour.label}
								</span>
							</div>
						</div>
					</div>
				</a>
			))}
		</div>
		{/* Dot indicators */}
		<div class="tours-dots flex justify-center gap-1.5 mt-4">
			{tours.map((_, i) => (
				<button
					class:list={["h-1.5 rounded-full transition-all duration-300", i === 0 ? "w-6 bg-gray-800" : "w-1.5 bg-gray-400"]}
					aria-label={`Go to tour ${i + 1}`}
					data-dot={i}
				/>
			))}
		</div>
	</div>
</div>

<script>
	document.querySelectorAll<HTMLDivElement>('.tours-slider').forEach(slider => {
		const track = slider.querySelector<HTMLDivElement>('.tours-track')!;
		const dots = slider.querySelectorAll<HTMLButtonElement>('.tours-dots button');
		const total = slider.querySelectorAll('.tours-slide').length;
		if (total === 0) return;

		let current = 0;

		function goTo(idx: number) {
			current = Math.max(0, Math.min(idx, total - 1));
			track.style.transform = `translateX(-${current * 100}%)`;
			dots.forEach((dot, i) => {
				dot.className = i === current
					? 'h-1.5 rounded-full transition-all duration-300 w-6 bg-gray-800'
					: 'h-1.5 rounded-full transition-all duration-300 w-1.5 bg-gray-400';
			});
		}

		// Dots
		dots.forEach((dot, i) => {
			dot.addEventListener('click', () => goTo(i));
		});

		// Touch/swipe
		let touchStartX = 0;
		let touchStartY = 0;
		const minSwipe = 50;

		slider.addEventListener('touchstart', (e) => {
			touchStartX = e.touches[0].clientX;
			touchStartY = e.touches[0].clientY;
		}, { passive: true });

		slider.addEventListener('touchend', (e) => {
			const dx = e.changedTouches[0].clientX - touchStartX;
			const dy = e.changedTouches[0].clientY - touchStartY;
			if (Math.abs(dx) > minSwipe && Math.abs(dx) > Math.abs(dy)) {
				if (dx < 0) goTo(current + 1); else goTo(current - 1);
			}
		}, { passive: true });
	});
</script>
