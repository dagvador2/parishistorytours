---
interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
const currentLocale = Astro.locals.lang;
const pathname = Astro.url.pathname;

// Compute base path (without /fr prefix) - works with both direct and rewritten URLs
const basePath = pathname.startsWith('/fr') ? (pathname.replace(/^\/fr/, '') || '/') : pathname;
const englishUrl = basePath;
const frenchUrl = basePath === '/' ? '/fr' : `/fr${basePath}`;

const activeClass = dark ? 'bg-white text-gray-800 font-semibold' : 'bg-blue-600 text-white';
const inactiveClass = dark ? 'text-gray-300 hover:text-white' : 'text-gray-600 hover:text-blue-600';
const separatorClass = dark ? 'text-gray-400' : 'text-gray-400';
---

<div class="flex items-center gap-2">
  <a
    href={englishUrl}
    class={`px-2 py-1 text-sm rounded transition-colors ${currentLocale === 'en' ? activeClass : inactiveClass}`}
  >
    EN
  </a>
  <span class={separatorClass}>|</span>
  <a
    href={frenchUrl}
    class={`px-2 py-1 text-sm rounded transition-colors ${currentLocale === 'fr' ? activeClass : inactiveClass}`}
  >
    FR
  </a>
</div>
