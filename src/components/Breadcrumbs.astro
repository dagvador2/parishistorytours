---
import JsonLd from './JsonLd.astro';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const origin = Astro.url.origin;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    ...(item.href ? { "item": `${origin}${item.href}` } : {})
  }))
};
---

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 pt-6 pb-2">
  <ol class="flex items-center flex-wrap text-sm text-gray-500">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && <span class="mx-2 text-gray-400">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-gray-800 transition-colors">{item.label}</a>
        ) : (
          <span class="text-gray-800 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<JsonLd data={breadcrumbSchema} />
