---
import { useTranslations } from '../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);
const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';
---

<footer class="bg-gray-900 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-xl font-bold mb-4">Paris History Tours</h3>
        <p class="text-gray-300 mb-4">
          {t('footer.description')}
        </p>
        <div class="flex space-x-4">
        </div>
      </div>

      <!-- Tours Section -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t('footer.tours')}</h4>
        <ul class="space-y-2">
          <li><a href={`${langPrefix}/`} class="text-gray-300 hover:text-white transition-colors">{t('footer.home')}</a></li>
          <li><a href={`${langPrefix}/tours/left-bank`} class="text-gray-300 hover:text-white transition-colors">{t('footer.leftBankTour')}</a></li>
          <li><a href={`${langPrefix}/tours/right-bank`} class="text-gray-300 hover:text-white transition-colors">{t('footer.rightBankTour')}</a></li>
          <li><a href={`${langPrefix}/tours/general-history`} class="text-gray-300 hover:text-white transition-colors">{t('footer.generalHistoryTour')}</a></li>
        </ul>
      </div>

      <!-- Info Section -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t('footer.info')}</h4>
        <ul class="space-y-2">
          <li><a href={`${langPrefix}/key-figures`} class="text-gray-300 hover:text-white transition-colors">{t('footer.aboutMe')}</a></li>
          <li><a href={`${langPrefix}/blog`} class="text-gray-300 hover:text-white transition-colors">Blog</a></li>
        </ul>
      </div>

      <!-- Contact Section -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t('footer.contact')}</h4>
        <ul class="space-y-2">
          <li>
            <a href="https://wa.me/+33620622480" class="text-gray-300 hover:text-white transition-colors flex items-center gap-2">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/>
              </svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href="mailto:clemdaguetschott@gmail.com" class="text-gray-300 hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
              Email
            </a>
          </li>
          <li>
            <a href="https://maps.app.goo.gl/AGYuzh8jHA9KXv9h8" class="text-gray-300 hover:text-white transition-colors flex items-center gap-2">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              Google Maps
            </a>
          </li>
          {
            import.meta.env.PUBLIC_INSTAGRAM_URL ? (
              <li>
                <a href={import.meta.env.PUBLIC_INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-colors flex items-center gap-2">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm0 2a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H7z" />
                    <path d="M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9zm0 2a2.5 2.5 0 100 5 2.5 2.5 0 000-5zM17.8 6.2a.9.9 0 11-1.8 0 .9.9 0 011.8 0z"/>
                  </svg>
                  Instagram
                </a>
              </li>
            ) : null
          }
        </ul>
      </div>
    </div>

    <!-- Also available on -->
    <div class="mt-8">
      <h5 class="text-sm font-semibold text-gray-400 mb-3">{t('footer.alsoOn')}</h5>
      <div class="flex items-center gap-4 flex-wrap">
        <a href="https://www.getyourguide.com/paris-l16/world-war-ii-tour-in-paris-fall-resistance-liberation-t537162/"
           target="_blank" rel="noopener noreferrer"
           class="bg-white/90 rounded-lg px-3 py-2 hover:bg-white transition-colors">
          <img src="/logos/get your guide logo.webp" alt="GetYourGuide" width="112" height="37" class="w-28 h-8 object-contain" />
        </a>
        <a href="https://www.viator.com/tours/Paris/World-War-II-Tour-in-Paris-Fall-Resistance-and-Liberation/d479-5642691P2"
           target="_blank" rel="noopener noreferrer"
           class="bg-white/90 rounded-lg px-3 py-2 hover:bg-white transition-colors">
          <img src="/logos/Viator_Logo.png" alt="Viator" width="112" height="28" class="w-24 h-6 object-contain" />
        </a>
        <a href="https://www.tripadvisor.fr/Attraction_Review-g187147-d34229671-Reviews-Paris_History_Tours-Paris_Ile_de_France.html"
           target="_blank" rel="noopener noreferrer"
           class="bg-white/90 rounded-lg px-3 py-2 hover:bg-white transition-colors">
          <img src="/logos/Tripadvisor-Logo.png" alt="TripAdvisor" width="112" height="63" class="w-28 h-8 object-contain" />
        </a>
        <a href="https://tourist.com/p/24194"
           target="_blank" rel="noopener noreferrer"
           class="bg-white/90 rounded-lg px-3 py-2 hover:bg-white transition-colors">
          <img src="/logos/tourist_logo.svg" alt="Tourist.com" width="112" height="38" class="w-24 h-6 object-contain" />
        </a>
        <a href="https://parisjetaime.com/activite/Paris-history-tours-p4833"
           target="_blank" rel="noopener noreferrer"
           class="bg-white/90 rounded-lg p-2 hover:bg-white transition-colors">
          <img src="/logos/parisjetaime_logo.svg" alt="Paris je t'aime — Office du Tourisme" width="38" height="38" class="w-7 h-7 object-contain" />
        </a>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-300 text-sm">
          &copy; {new Date().getFullYear()} {t('footer.copyright')}
        </p>
      </div>
    </div>
  </div>
</footer>
