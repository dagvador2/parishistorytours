---
/**
 * KeyFiguresStats — Animated statistics cards.
 * Data is passed as props (fetched server-side). Number ticker uses
 * IntersectionObserver + CSS animations instead of framer-motion.
 */
interface Stat {
  id: string;
  label: string;
  value: number;
  color: 'blue' | 'green' | 'purple' | 'orange';
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;

const colorConfig = {
  blue:   { bg: 'bg-blue-50',    text: 'text-blue-600',    border: 'border-blue-100',    glow: 'shadow-blue-100/50',    gradient: 'from-blue-400 to-blue-600' },
  green:  { bg: 'bg-emerald-50', text: 'text-emerald-600', border: 'border-emerald-100', glow: 'shadow-emerald-100/50', gradient: 'from-emerald-400 to-emerald-600' },
  purple: { bg: 'bg-violet-50',  text: 'text-violet-600',  border: 'border-violet-100',  glow: 'shadow-violet-100/50',  gradient: 'from-violet-400 to-violet-600' },
  orange: { bg: 'bg-amber-50',   text: 'text-amber-600',   border: 'border-amber-100',   glow: 'shadow-amber-100/50',   gradient: 'from-amber-400 to-amber-600' },
};

const icons = {
  participants: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />',
  sessions: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />',
  kilometers: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />',
  countries: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />',
};
---

<div class="kf-stats grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
  {stats.map((stat, index) => {
    const colors = colorConfig[stat.color];
    return (
      <div
        class={`kf-card relative overflow-hidden bg-white rounded-2xl border ${colors.border} p-5 md:p-6 text-center shadow-lg ${colors.glow} hover:shadow-xl transition-shadow duration-300 opacity-0 translate-y-8`}
        style={`transition-delay: ${index * 100}ms`}
      >
        <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colors.gradient}`} />
        <div class={`w-14 h-14 mx-auto mb-4 rounded-xl ${colors.bg} ${colors.text} flex items-center justify-center`}>
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" set:html={icons[stat.id as keyof typeof icons]} />
        </div>
        <div class="text-3xl md:text-4xl font-bold text-gray-900 mb-1">
          <span class="kf-number tabular-nums" data-target={stat.value}>0</span>
        </div>
        <div class="text-sm md:text-base text-gray-500 font-medium">{stat.label}</div>
      </div>
    );
  })}
</div>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Reveal cards with staggered animation
        const cards = entry.target.querySelectorAll<HTMLDivElement>('.kf-card');
        cards.forEach(card => {
          card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        });

        // Animate numbers
        entry.target.querySelectorAll<HTMLSpanElement>('.kf-number').forEach(el => {
          const target = parseInt(el.dataset.target || '0');
          if (target === 0) return;
          const duration = 1500;
          const start = performance.now();
          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease-out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(eased * target).toLocaleString('en-US');
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });

        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.kf-stats').forEach(el => observer.observe(el));
</script>
