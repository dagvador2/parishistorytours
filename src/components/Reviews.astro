---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// reviews will be fetched from the server (Google Places) via /api/google-reviews
let reviews = [];
---

{/* Section Reviews */}
<div id="reviews" class="mb-16">
	<h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-gray-800">{t('reviews.title')}</h2>
	<p class="text-center text-gray-600 mb-12 text-lg">{t('reviews.subtitle')}</p>
	
	{/* Carrousel de reviews */}
	<div class="relative max-w-4xl mx-auto overflow-hidden">
				<div class="flex transition-transform duration-500 ease-in-out" id="review-carousel">
					<!-- slides will be injected here by client script (Google reviews) -->
				</div>
		
		{/* Boutons de navigation */}
		<button id="prev-review" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white rounded-full p-2 shadow-lg hover:bg-gray-50 transition cursor-pointer">
			<svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
			</svg>
		</button>
		<button id="next-review" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white rounded-full p-2 shadow-lg hover:bg-gray-50 transition cursor-pointer">
			<svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
			</svg>
		</button>
		
		{/* Indicateurs */}
		<div class="flex justify-center mt-6 space-x-2" id="review-indicators">
			{Array.from({ length: 4 }, (_, i) => (
				<button class={`w-3 h-3 rounded-full transition cursor-pointer ${i === 0 ? 'bg-gray-800' : 'bg-gray-300'}`} data-index={i}></button>
			))}
		</div>
	</div>
	
	{/* Liens vers les plateformes */}
	<div class="flex flex-col md:flex-row justify-center items-center gap-4 md:gap-8 mt-8">
		<a href="https://www.freetour.com/paris/second-world-war-tour-in-paris-fall-resistance-liberation" target="_blank" class="flex items-center gap-2 text-gray-700 hover:text-gray-900 underline transition text-sm text-center">
			<img 
				src="/logos/Freetour_logo.png"
				alt="Freetour logo" 
				class="w-6 h-6 object-contain"
			/>
			<span>{t('reviews.seeMore')}</span>
		</a>
		<span class="text-gray-400 hidden md:inline">|</span>
		<a href="https://maps.app.goo.gl/1ZmS5861XDPsM1Dk7" target="_blank" class="flex items-center gap-2 text-gray-700 hover:text-gray-900 underline transition text-sm text-center">
			<img 
				src={"/logos/Google__logo.webp"}
				alt="Google logo" 
				class="w-6 h-6 object-contain"
			/>
			<span>{t('reviews.findUs')}</span>
		</a>
	</div>
</div>

<script type="module">
(() => {
	// client-side: fetch Google reviews and inject slides while keeping the visual structure
		const container = document.getElementById('review-carousel');
		const indicatorsContainer = document.getElementById('review-indicators');
	const prevBtn = document.getElementById('prev-review');
	const nextBtn = document.getElementById('next-review');

		if (!container || !indicatorsContainer) return;

		// Aggressively clear any existing intervals that might be causing auto-rotation.
		// Note: this clears all intervals up to the current highest id. It's aggressive but guarantees no hidden timers keep rotating the carousel.
		try {
			const highest = window.setInterval(() => {}, 1000);
			for (let i = 0; i <= highest; i++) {
				try { clearInterval(i); } catch (e) {}
			}
			// also clear any known stored interval id
			if (window.__reviewsAutoRotateInterval) {
				try { clearInterval(window.__reviewsAutoRotateInterval); } catch (e) {}
				delete window.__reviewsAutoRotateInterval;
			}
		} catch (e) {
			// ignore
		}

	const loadingHtml = '<div class="p-8 text-center text-gray-600">' + (window?.ASTRO?.env?.REVIEWS_LOADING_LABEL || 'Loading reviews...') + '</div>';
	container.innerHTML = loadingHtml;

	function escapeHtml(str) {
		if (!str) return '';
		return String(str).replace(/[&<>\"]/g, function (s) {
			const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' };
			return map[s];
		});
	}

	async function fetchWithTimeout(url, opts = {}, timeout = 7000) {
		const controller = new AbortController();
		const id = setTimeout(() => controller.abort(), timeout);
		try {
			const res = await fetch(url, { signal: controller.signal, ...opts });
			return res;
		} finally {
			clearTimeout(id);
		}
	}

	(async () => {
		let payload;
		try {
			const res = await fetchWithTimeout('/api/google-reviews');
			payload = await res.json();
			if (!res.ok || payload.error) {
				const detail = payload?.body || payload?.error || payload?.message || '';
				container.innerHTML = '<div class="p-8 text-center text-red-600">' + escapeHtml('Reviews currently unavailable') + (detail ? ': ' + escapeHtml(detail) : '') + '</div>';
				console.error('google-reviews error', payload);
				return;
			}
		} catch (err) {
			console.error('fetch reviews error', err);
			const msg = err && err.name === 'AbortError' ? 'Request timed out' : (err && err.message ? err.message : String(err));
			container.innerHTML = '<div class="p-8 text-center text-red-600">' + escapeHtml('Reviews currently unavailable') + ': ' + escapeHtml(msg) + '</div>';
			return;
		}

		const reviews = payload.reviews || [];
		if (!reviews.length) {
			container.innerHTML = '<div class="p-8 text-center text-gray-600">' + escapeHtml('No reviews yet') + '</div>';
			return;
		}

		// Build slides
		const frag = document.createDocumentFragment();
		reviews.forEach((r) => {
			const slide = document.createElement('div');
			slide.className = 'min-w-full px-4';

			const card = document.createElement('div');
			card.className = 'bg-white rounded-xl shadow-lg p-8 mx-auto max-w-3xl border border-gray-100 min-h-96 flex flex-col';

			// header
			const header = document.createElement('div');
			header.className = 'flex items-center justify-between mb-4 gap-4';
			const stars = document.createElement('div');
			stars.className = 'flex text-yellow-400';
			for (let i = 0; i < 5; i++) {
				const span = document.createElement('span');
				span.innerHTML = '<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
				stars.appendChild(span);
			}
			const dateEl = document.createElement('span');
			dateEl.className = 'text-sm text-gray-500';
			if (r.time) {
				try { dateEl.textContent = new Date(r.time * 1000).toLocaleDateString(); } catch (e) {}
			}
			header.appendChild(stars);
			header.appendChild(dateEl);

			// body: full review text in bold (no title)
			const body = document.createElement('div');
			body.className = 'flex-1 flex flex-col overflow-hidden';
			const bodyText = document.createElement('div');
			bodyText.className = 'text-gray-700 leading-relaxed mb-4 flex-1 break-words font-bold';
			bodyText.textContent = r.text || r.review || '';
			body.appendChild(bodyText);

			// footer
			const footer = document.createElement('div');
			footer.className = 'border-t border-gray-100 pt-4 mt-auto flex-shrink-0';
			const footerInner = document.createElement('div');
			footerInner.className = 'flex items-center justify-between';
			const left = document.createElement('div');
			left.className = 'flex items-center gap-2';
			const img = document.createElement('img');
			img.src = r.profile_photo_url || '/guide-photo.webp';
			img.alt = r.name || '';
			img.className = 'w-10 h-10 rounded-full object-cover';
			const meta = document.createElement('div');
			meta.className = 'flex flex-col';
			const authorEl = document.createElement('span');
			authorEl.className = 'text-sm font-medium text-gray-600';
			authorEl.textContent = r.name || '';
			const platformEl = document.createElement('span');
			platformEl.className = 'text-xs text-gray-400';
			platformEl.textContent = 'Google Maps';
			meta.appendChild(authorEl);
			meta.appendChild(platformEl);
			left.appendChild(img);
			left.appendChild(meta);
			footerInner.appendChild(left);
			footer.appendChild(footerInner);

			card.appendChild(header);
			card.appendChild(body);
			card.appendChild(footer);
			slide.appendChild(card);
			frag.appendChild(slide);
		});

		container.innerHTML = '';
		container.appendChild(frag);

			// indicators
			indicatorsContainer.innerHTML = '';
		const slides = container.querySelectorAll('.min-w-full');
		let currentIndex = 0;
		slides.forEach((_, i) => {
			const btn = document.createElement('button');
			btn.className = i === 0 ? 'w-3 h-3 rounded-full transition bg-gray-800' : 'w-3 h-3 rounded-full transition bg-gray-300';
			btn.dataset.index = String(i);
			btn.addEventListener('click', () => { currentIndex = i; update(); });
			indicatorsContainer.appendChild(btn);
		});

		const total = slides.length;
		const carousel = container;

		function update() {
			const offset = -currentIndex * 100;
			carousel.style.transform = `translateX(${offset}%)`;
			indicatorsContainer.querySelectorAll('button').forEach((b, idx) => {
				b.classList.toggle('bg-gray-800', idx === currentIndex);
				b.classList.toggle('bg-gray-300', idx !== currentIndex);
			});
		}

		function next() { currentIndex = (currentIndex + 1) % total; update(); }
		function prev() { currentIndex = (currentIndex - 1 + total) % total; update(); }

		if (nextBtn) nextBtn.addEventListener('click', next);
		if (prevBtn) prevBtn.addEventListener('click', prev);

		// swipe
		let sx = 0; let sy = 0; const minSwipe = 50;
		carousel.addEventListener('touchstart', e => { sx = e.changedTouches[0].screenX; sy = e.changedTouches[0].screenY; }, { passive: true });
		carousel.addEventListener('touchend', e => {
			const ex = e.changedTouches[0].screenX; const ey = e.changedTouches[0].screenY;
			const dx = ex - sx; const dy = ey - sy;
			if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > minSwipe) { if (dx > 0) prev(); else next(); }
		}, { passive: true });
			// Ensure any leftover auto-rotation interval from previous scripts is cleared
			try {
				if (window.__reviewsAutoRotateInterval) {
					clearInterval(window.__reviewsAutoRotateInterval);
					delete window.__reviewsAutoRotateInterval;
				}
			} catch (e) {}

			// Show only the initial review by default and ensure indicators reflect it
			update();

				// Summary: average rating and total count (display below indicators)
				try {
					const totalCount = (payload && (payload.total || payload.total === 0)) ? payload.total : reviews.length;
					const avg = (payload && (payload.average_rating || payload.average_rating === 0)) ? payload.average_rating : (() => {
						let sum = 0; let cnt = 0;
						for (const rr of reviews) { const rnum = Number(rr.rating ?? rr.rate ?? rr.stars ?? 0); if (!isNaN(rnum) && rnum > 0) { sum += rnum; cnt++; } }
						return cnt ? Math.round((sum / cnt) * 10) / 10 : null;
					})();
					const summaryEl = document.createElement('div');
					summaryEl.className = 'mt-4 text-center text-sm text-gray-600';
					summaryEl.innerHTML = `<span class="font-semibold text-gray-800">${avg !== null ? avg : '—'}</span> <span class="text-gray-500">/ 5</span> · <span class="text-gray-700">${totalCount}</span> avis`;
					indicatorsContainer.parentNode.insertBefore(summaryEl, indicatorsContainer.nextSibling);
				} catch (e) {
					console.warn('Could not render reviews summary', e);
				}

			// Auto-rotation disabled per UX: users navigate manually via swipe or buttons
	})();
})();
</script>
