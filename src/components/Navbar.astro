---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  variant: 'homepage' | 'tour' | 'fixed';
  links?: Array<{ label: string; href: string }>;
  bookLabel?: string;
  bookTarget?: string;
  priceLabel?: string;
}

const lang = Astro.locals.lang;
const t = useTranslations(lang);
const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';

const {
  variant,
  links,
  bookLabel = t('nav.bookTour'),
  bookTarget = '#book-tour',
  priceLabel,
} = Astro.props;

const mobileBookLabel = priceLabel || bookLabel;
---

{variant === 'homepage' && (
  <!-- Desktop scroll banner -->
  <nav id="book-banner-desktop" class="hidden md:block fixed top-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-b border-amber-900/30 z-[9999] shadow-[0_2px_20px_rgba(0,0,0,0.3)] transform -translate-y-full transition-transform duration-300">
    <div class="max-w-5xl mx-auto flex items-center justify-between py-3 px-6">
      <span class="text-amber-100/90 font-semibold tracking-wide text-sm">Paris History Tours</span>
      <div class="flex items-center gap-6">
        <a href={`${langPrefix}/tours/left-bank`} class="text-gray-300 font-medium hover:text-white transition-colors duration-200 text-sm">{t('nav.leftBank')}</a>
        <button id="book-btn-desktop" class="bg-amber-600 text-white font-semibold hover:bg-amber-500 transition-all duration-200 px-6 py-2.5 rounded-lg shadow-lg shadow-amber-900/30 hover:shadow-amber-800/40 text-sm tracking-wide">{bookLabel}</button>
        <a href={`${langPrefix}/tours/right-bank`} class="text-gray-300 font-medium hover:text-white transition-colors duration-200 text-sm">{t('nav.rightBank')}</a>
      </div>
      <LanguageSwitcher dark />
    </div>
  </nav>

  <!-- Mobile scroll banner (TOP) -->
  <nav id="book-banner-mobile" class="md:hidden fixed top-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-b border-amber-900/30 z-[9998] shadow-[0_2px_20px_rgba(0,0,0,0.3)] transform -translate-y-full transition-transform duration-300">
    <div class="flex items-center justify-between py-3 px-4">
      <span class="text-amber-100/90 font-semibold tracking-wide text-sm">Paris History Tours</span>
      <div class="flex items-center gap-3">
        <button id="book-btn-mobile" class="bg-amber-600 text-white font-semibold hover:bg-amber-500 transition-colors duration-200 px-5 py-2 rounded-lg shadow-md text-sm">{bookLabel}</button>
        <LanguageSwitcher dark />
      </div>
    </div>
  </nav>

  <!-- Mobile CTA fixed bottom bar -->
  <div id="book-cta-mobile" class="md:hidden fixed bottom-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-t border-amber-900/30 z-[9998] shadow-[0_-2px_20px_rgba(0,0,0,0.3)] p-3 transform translate-y-full transition-transform duration-300">
    <button id="book-btn-mobile-bottom" class="w-full bg-amber-600 text-white font-bold py-3 rounded-lg text-lg hover:bg-amber-500 transition-colors shadow-lg shadow-amber-900/30">{mobileBookLabel}</button>
  </div>
)}

{variant === 'tour' && (
  <!-- Desktop top banner for tour pages -->
  <nav id="book-banner" class="fixed top-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-b border-amber-900/30 z-[9998] shadow-[0_2px_20px_rgba(0,0,0,0.3)] transform -translate-y-full transition-transform duration-300">
    <div class="flex items-center justify-between py-3 px-4">
      <span class="flex-1 text-amber-100/90 font-semibold tracking-wide text-sm">Paris History Tours</span>
      <button id="book-btn-tour-page" class="bg-amber-600 text-white font-semibold hover:bg-amber-500 transition-all duration-200 px-6 py-2.5 rounded-lg shadow-lg shadow-amber-900/30 text-sm tracking-wide">{bookLabel}</button>
      <div class="flex-1 flex justify-end">
        <LanguageSwitcher dark />
      </div>
    </div>
  </nav>

  <!-- Mobile CTA fixed bottom bar for tour pages -->
  <div id="book-cta-mobile-tour" class="md:hidden fixed bottom-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-t border-amber-900/30 z-[9998] shadow-[0_-2px_20px_rgba(0,0,0,0.3)] p-3 transform translate-y-full transition-transform duration-300">
    <button id="book-btn-mobile-bottom-tour" class="w-full bg-amber-600 text-white font-bold py-3 rounded-lg text-lg hover:bg-amber-500 transition-colors shadow-lg shadow-amber-900/30">{mobileBookLabel}</button>
  </div>
)}

{variant === 'fixed' && (
  <nav class="fixed top-0 left-0 w-full bg-gray-900/95 backdrop-blur-md border-b border-amber-900/30 z-[9999] shadow-[0_2px_20px_rgba(0,0,0,0.3)] hidden md:block">
    <div class="max-w-5xl mx-auto flex items-center justify-between py-3 px-6">
      <span class="text-amber-100/90 font-semibold tracking-wide text-sm">Paris History Tours</span>
      <div class="flex items-center gap-6">
        {links?.map(link => (
          <a href={link.href} class="text-gray-300 font-medium hover:text-white transition-colors duration-200 text-sm">{link.label}</a>
        ))}
        <a href={bookTarget} class="bg-amber-600 text-white font-semibold hover:bg-amber-500 transition-all duration-200 px-6 py-2.5 rounded-lg shadow-lg shadow-amber-900/30 text-sm tracking-wide">{bookLabel}</a>
      </div>
      <LanguageSwitcher dark />
    </div>
  </nav>
)}
