---
import { useTranslations } from '../../i18n/utils';
import type { CoGuide } from '../../data/tours';

interface Props {
  coGuides: CoGuide[];
}

const { coGuides } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section class="qcog">
  <div class="qcog__inner">
    <header class="qcog__header">
      <p class="qcog__kicker">{t('quiet.tour.coGuide.kicker')}</p>
      <h2 class="qcog__title">{t('quiet.tour.coGuide.title')}</h2>
      <p class="qcog__subtitle">{t('quiet.tour.coGuide.subtitle')}</p>
    </header>

    <div class={`qcog__grid qcog__grid--${coGuides.length}`}>
      {coGuides.map((g) => (
        <article class="qcog__card">
          <div class="qcog__photo">
            <img src={g.photo} alt={`Portrait — ${t(`quiet.tour.coGuide.${g.id}.role`)}`} loading="lazy" decoding="async" />
          </div>
          <div class="qcog__body">
            <p class="qcog__role">{t(`quiet.tour.coGuide.${g.id}.role`)}</p>
            <h3 class="qcog__name">
              {g.id === 'clement' ? 'Clément Daguet-Schott' : g.id === 'amelie' ? 'Amélie Leynier' : ''}
            </h3>
            <p class="qcog__bio">{t(`quiet.tour.coGuide.${g.id}.bio`)}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .qcog {
    background: var(--paper);
    padding: 96px 32px;
    border-top: 1px solid var(--border);
  }
  .qcog__inner { max-width: 1280px; margin: 0 auto; }
  .qcog__header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
  }
  .qcog__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qcog__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 52px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .qcog__subtitle {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }

  .qcog__grid {
    display: grid;
    gap: 56px;
  }
  .qcog__grid--2 { grid-template-columns: 1fr 1fr; }
  .qcog__grid--1 { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; }
  .qcog__grid--3 { grid-template-columns: repeat(3, 1fr); gap: 40px; }

  .qcog__card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .qcog__photo {
    aspect-ratio: 5 / 6;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
  }
  .qcog__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .qcog__card:hover .qcog__photo img { transform: scale(1.03); }

  .qcog__body { display: flex; flex-direction: column; gap: 12px; }
  .qcog__role {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0;
  }
  .qcog__name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    color: var(--ink);
    margin: 0;
    line-height: 1.15;
  }
  .qcog__bio {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0;
  }

  @media (max-width: 900px) {
    .qcog { padding: 64px 0; }
    .qcog__header { margin: 0 24px 40px; }
    .qcog__grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 85%;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 24px 16px;
      scroll-padding: 0 24px;
    }
    .qcog__grid::-webkit-scrollbar { display: none; }
    .qcog__card {
      scroll-snap-align: start;
      gap: 20px;
    }
    .qcog__photo { aspect-ratio: 4 / 5; }
  }
</style>
