---
import { useTranslations } from '../../i18n/utils';

interface Post {
  id: string;
  data: {
    title: string;
    description: string;
    publishDate: Date;
    tags: string[];
    image?: string;
    imageAlt?: string;
  };
}

interface Props {
  posts: Post[];
  langPrefix: string;
}

const { posts, langPrefix } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);

const dateLocale = lang === 'fr' ? 'fr-FR' : 'en-US';
const featured = posts[0];
const rest = posts.slice(1);

const fmtDate = (d: Date) => d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="qbloglist">
  <div class="qbloglist__inner">
    {posts.length === 0 && (
      <p class="qbloglist__empty">{t('quiet.blog.empty')}</p>
    )}

    {featured && (
      <a href={`${langPrefix}/blog/${featured.id}`} class="qbloglist__feature">
        {featured.data.image && (
          <div class="qbloglist__feature-img">
            <img src={featured.data.image} alt={featured.data.imageAlt || featured.data.title} loading="lazy" decoding="async" />
          </div>
        )}
        <div class="qbloglist__feature-body">
          <div class="qbloglist__meta">
            <time datetime={featured.data.publishDate.toISOString()}>{fmtDate(featured.data.publishDate)}</time>
            {featured.data.tags[0] && <span class="qbloglist__meta-sep" aria-hidden="true">·</span>}
            {featured.data.tags[0] && <span class="qbloglist__tag">{featured.data.tags[0]}</span>}
          </div>
          <h2 class="qbloglist__feature-title">{featured.data.title}</h2>
          <p class="qbloglist__feature-desc">{featured.data.description}</p>
          <span class="qbloglist__cta">{t('quiet.blog.readCta')} <span aria-hidden="true">→</span></span>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <div class="qbloglist__grid">
        {rest.map((post) => (
          <a href={`${langPrefix}/blog/${post.id}`} class="qbloglist__card">
            {post.data.image && (
              <div class="qbloglist__card-img">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" decoding="async" />
              </div>
            )}
            <div class="qbloglist__card-body">
              <div class="qbloglist__meta">
                <time datetime={post.data.publishDate.toISOString()}>{fmtDate(post.data.publishDate)}</time>
                {post.data.tags[0] && <span class="qbloglist__meta-sep" aria-hidden="true">·</span>}
                {post.data.tags[0] && <span class="qbloglist__tag">{post.data.tags[0]}</span>}
              </div>
              <h3 class="qbloglist__card-title">{post.data.title}</h3>
              <p class="qbloglist__card-desc">{post.data.description}</p>
              <span class="qbloglist__cta qbloglist__cta--sm">{t('quiet.blog.readCta')} <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .qbloglist {
    background: var(--paper);
    padding: 64px 32px 96px;
  }
  .qbloglist__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .qbloglist__empty {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink-2);
    text-align: center;
    padding: 48px 0;
  }

  /* --- Meta row --- */
  .qbloglist__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-bottom: 14px;
  }
  .qbloglist__meta-sep { color: var(--border); }
  .qbloglist__tag { color: var(--rouge); }

  /* --- Feature block --- */
  .qbloglist__feature {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
    text-decoration: none;
    color: inherit;
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .qbloglist__feature:hover .qbloglist__feature-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .qbloglist__feature:hover .qbloglist__feature-img img {
    transform: scale(1.02);
  }
  .qbloglist__feature-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
  }
  .qbloglist__feature-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .qbloglist__feature-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 3.6vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 20px;
    max-width: 18ch;
  }
  .qbloglist__feature-desc {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 24px;
    max-width: 52ch;
  }

  /* --- Grid --- */
  .qbloglist__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 56px;
    padding-top: 56px;
  }
  .qbloglist__card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-decoration: none;
    color: inherit;
  }
  .qbloglist__card:hover .qbloglist__card-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .qbloglist__card:hover .qbloglist__card-img img {
    transform: scale(1.02);
  }
  .qbloglist__card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
  }
  .qbloglist__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .qbloglist__card-body { display: flex; flex-direction: column; }
  .qbloglist__card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .qbloglist__card-desc {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .qbloglist__cta {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .qbloglist__cta span { transition: transform 160ms ease; }
  .qbloglist__feature:hover .qbloglist__cta span,
  .qbloglist__card:hover .qbloglist__cta span {
    transform: translateX(4px);
  }
  .qbloglist__cta--sm { font-size: 12px; }

  @media (max-width: 900px) {
    .qbloglist__feature {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 32px 0;
    }
    .qbloglist__grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-top: 40px;
    }
  }

  @media (max-width: 760px) {
    .qbloglist { padding: 48px 20px 64px; }
    .qbloglist__feature-title { font-size: 28px; }
    .qbloglist__card-title { font-size: 22px; }
  }
</style>
