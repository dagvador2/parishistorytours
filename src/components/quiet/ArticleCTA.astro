---
import { useTranslations } from '../../i18n/utils';

interface Props {
  bookHref: string;
  toursHref: string;
}

const { bookHref, toursHref } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section class="qarcta">
  <div class="qarcta__inner">
    <p class="qarcta__kicker">{t('quiet.blog.ctaKicker')}</p>
    <h2 class="qarcta__title">{t('quiet.blog.ctaHeading')}</h2>
    <p class="qarcta__desc">{t('quiet.blog.ctaDescription')}</p>
    <div class="qarcta__actions">
      <a href={bookHref} class="qarcta__btn qarcta__btn--primary">{t('quiet.blog.ctaPrimary')}</a>
      <a href={toursHref} class="qarcta__btn qarcta__btn--ghost">{t('quiet.blog.ctaSecondary')} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<style>
  .qarcta {
    background: var(--paper-2);
    padding: 80px 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .qarcta__inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: left;
  }
  .qarcta__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 20px;
  }
  .qarcta__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 44px);
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 20px;
    max-width: 20ch;
  }
  .qarcta__desc {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 32px;
    max-width: 52ch;
  }
  .qarcta__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .qarcta__btn {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 14px 24px;
    border-radius: 2px;
    text-decoration: none;
    border: 1px solid var(--ink);
    transition: background 140ms ease, color 140ms ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .qarcta__btn--primary {
    background: var(--ink);
    color: var(--paper-3);
  }
  .qarcta__btn--primary:hover {
    background: transparent;
    color: var(--ink);
  }
  .qarcta__btn--ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--border);
  }
  .qarcta__btn--ghost:hover {
    border-color: var(--ink);
  }
  .qarcta__btn--ghost span { transition: transform 160ms ease; }
  .qarcta__btn--ghost:hover span { transform: translateX(4px); }

  @media (max-width: 760px) {
    .qarcta { padding: 56px 20px; }
    .qarcta__title { font-size: 30px; }
    .qarcta__actions { flex-direction: column; align-items: stretch; }
    .qarcta__btn { justify-content: center; text-align: center; }
  }
</style>
