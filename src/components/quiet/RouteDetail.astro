---
import { useTranslations } from '../../i18n/utils';
import TourMap from '../TourMap.tsx';
import type { TourConfig } from '../../data/tours';

interface Props {
  tour: TourConfig;
  isGeneral: boolean;
}

const { tour, isGeneral } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);

const title = isGeneral ? t('quiet.tour.route.titleGeneral') : t('quiet.tour.route.titleWW2');
const subtitle = isGeneral ? t('quiet.tour.route.subtitleGeneral') : t('quiet.tour.route.subtitleWW2');
---

<section id="route" class="qrd">
  <div class="qrd__inner">
    <header class="qrd__header">
      <p class="qrd__kicker">{t('quiet.tour.route.kicker')}</p>
      <h2 class="qrd__title">{title}</h2>
      <p class="qrd__subtitle">{subtitle}</p>
    </header>

    <div class="qrd__map">
      <TourMap tour={tour.slug as 'left-bank' | 'right-bank' | 'general-history'} client:visible />
    </div>
  </div>
</section>

<style>
  .qrd { background: var(--paper-2); padding: 96px 32px; }
  .qrd__inner { max-width: 1280px; margin: 0 auto; }
  .qrd__header {
    text-align: center;
    margin: 0 auto 48px;
    max-width: 640px;
  }
  .qrd__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qrd__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(34px, 4vw, 48px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .qrd__subtitle {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0;
  }

  .qrd__map {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--paper-3);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .qrd__map > * { width: 100%; height: 100%; }

  @media (max-width: 900px) {
    .qrd { padding: 64px 20px; }
    .qrd__map { aspect-ratio: 4 / 3; }
  }
</style>
