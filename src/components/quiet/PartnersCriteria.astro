---
import { useTranslations } from '../../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const criteria = [
  {
    title: t('quiet.partners.criteria.items.met.title'),
    body: t('quiet.partners.criteria.items.met.body'),
  },
  {
    title: t('quiet.partners.criteria.items.quality.title'),
    body: t('quiet.partners.criteria.items.quality.body'),
  },
  {
    title: t('quiet.partners.criteria.items.independent.title'),
    body: t('quiet.partners.criteria.items.independent.body'),
  },
];
---

<section class="qpartnerscrit">
  <div class="qpartnerscrit__inner">
    <p class="qpartnerscrit__kicker">{t('quiet.partners.criteria.kicker')}</p>
    <h2 class="qpartnerscrit__title">{t('quiet.partners.criteria.title')}</h2>
    <ul class="qpartnerscrit__grid">
      {criteria.map((c) => (
        <li class="qpartnerscrit__item">
          <h3 class="qpartnerscrit__itemTitle">{c.title}</h3>
          <p class="qpartnerscrit__itemBody">{c.body}</p>
        </li>
      ))}
    </ul>
    <p class="qpartnerscrit__note">{t('quiet.partners.criteria.note')}</p>
  </div>
</section>

<style>
  .qpartnerscrit {
    background: var(--paper-2);
    padding: 80px 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .qpartnerscrit__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .qpartnerscrit__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qpartnerscrit__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 48px;
    max-width: 28ch;
  }
  .qpartnerscrit__grid {
    list-style: none;
    padding: 0;
    margin: 0 0 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .qpartnerscrit__item {
    border-top: 1px solid var(--ink);
    padding-top: 20px;
  }
  .qpartnerscrit__itemTitle {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    color: var(--ink);
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  .qpartnerscrit__itemBody {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }
  .qpartnerscrit__note {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    max-width: 72ch;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .qpartnerscrit__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .qpartnerscrit { padding: 56px 20px; }
    .qpartnerscrit__grid { grid-template-columns: 1fr; gap: 24px; }
    .qpartnerscrit__title { margin-bottom: 32px; }
  }
</style>
