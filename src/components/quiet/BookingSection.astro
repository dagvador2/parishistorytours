---
import { useTranslations } from '../../i18n/utils';
import BookTour from '../BookTour.astro';

interface Props {
  /** Passed through to the underlying BookingWizard for tour-detail pages. */
  tourFilter?: string;
}

const { tourFilter } = Astro.props;

const lang = Astro.locals.lang;
const t = useTranslations(lang);

// Widths are individually tuned so each logo reads at roughly equal visual weight
// despite very different intrinsic aspect ratios.
// Widths are individually tuned so each logo reads at roughly equal visual weight
// despite very different intrinsic aspect ratios.
const partners = [
  { name: 'GetYourGuide',    src: '/logos/get%20your%20guide%20logo.webp', href: 'https://www.getyourguide.com/paris-l16/world-war-ii-tour-in-paris-fall-resistance-liberation-t537162/',                          width: 140 },
  { name: 'Viator',          src: '/logos/Viator_Logo.png',                href: 'https://www.viator.com/tours/Paris/World-War-II-Tour-in-Paris-Fall-Resistance-and-Liberation/d479-5642691P2',                          width: 110 },
  { name: 'TripAdvisor',     src: '/logos/Tripadvisor-Logo.png',           href: 'https://www.tripadvisor.fr/Attraction_Review-g187147-d34229671-Reviews-Paris_History_Tours-Paris_Ile_de_France.html',                  width: 130 },
  { name: 'Tourist.com',     src: '/logos/tourist_logo.svg',               href: 'https://tourist.com/p/24194',                                                                                                        width: 105 },
  { name: "Paris je t'aime", src: '/logos/parisjetaime_logo.svg',          href: 'https://parisjetaime.com/activite/Paris-history-tours-p4833',                                                                      width: 44  },
];
---

<section id="book" class="qbook">
  <div class="qbook__inner">
    <header class="qbook__header">
      <p class="qbook__kicker">{t('quiet.home.booking.kicker')}</p>
      <h2 class="qbook__title">{t('quiet.home.booking.title')}</h2>
      <p class="qbook__desc">{t('quiet.home.booking.description')}</p>
    </header>

    <div class="qbook__chips">
      <a class="qbook__chip" href="https://wa.me/+33620622480" rel="noopener">
        <span class="qbook__chip-label">{t('quiet.home.booking.whatsappLabel')}</span>
        <span class="qbook__chip-value">+33 6 20 62 24 80</span>
      </a>
      <a class="qbook__chip" href="mailto:clemdaguetschott@gmail.com">
        <span class="qbook__chip-label">{t('quiet.home.booking.emailLabel')}</span>
        <span class="qbook__chip-value">clemdaguetschott@gmail.com</span>
      </a>
    </div>

    <div class="qbook__direct">
      <div class="qbook__direct-head">
        <p class="qbook__direct-heading">{t('quiet.home.booking.directHeading')}</p>
        <p class="qbook__direct-desc">{t('quiet.home.booking.directDescription')}</p>
      </div>
      <div class="qbook__wizard">
        <BookTour tourFilter={tourFilter} hideChrome={true} />
      </div>
    </div>

    <div class="qbook__partners">
      <span class="qbook__partners-label">{t('quiet.home.booking.partnerLabel')}</span>
      <div class="qbook__partner-row">
        {partners.map((p) => (
          <a href={p.href} class="qbook__partner" target="_blank" rel="noopener" aria-label={p.name} style={`--logo-w:${p.width}px`}>
            <img src={p.src} alt={p.name} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .qbook {
    background: var(--paper);
    padding: 96px 32px;
    border-top: 1px solid var(--border);
  }
  .qbook__inner { max-width: 1100px; margin: 0 auto; }
  .qbook__header { margin-bottom: 56px; max-width: 720px; }
  .qbook__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0 0 16px;
  }
  .qbook__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 48px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 24px;
    line-height: 1.1;
  }
  .qbook__desc {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }

  .qbook__partners {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    margin-top: 16px;
    text-align: center;
  }
  .qbook__partners-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .qbook__partner-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 48px;
  }
  .qbook__partner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    width: var(--logo-w, 120px);
    filter: grayscale(1);
    opacity: 0.55;
    transition: opacity 160ms ease, filter 160ms ease;
  }
  .qbook__partner:hover { opacity: 1; filter: grayscale(0); }
  .qbook__partner img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .qbook__chips {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .qbook__chip {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 20px 24px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--paper-3);
    text-decoration: none;
    transition: border-color 120ms ease;
  }
  .qbook__chip:hover { border-color: var(--ink); }
  .qbook__chip-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .qbook__chip-value {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--ink);
  }

  .qbook__direct {
    margin-top: 72px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }
  .qbook__direct-head { margin-bottom: 32px; }
  .qbook__direct-heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .qbook__direct-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 560px;
  }
  .qbook__wizard { margin-top: 8px; }
  /* Neutralize the wizard's own internal max-width/px-4 so it aligns with the section gutter */
  .qbook__wizard :global(#book-tour) { margin-bottom: 0; }
  .qbook__wizard :global(#book-tour > div) { max-width: none; padding: 0; }
  /* The wizard reserves min-h:400px for its step content to stabilize layout.
     On the initial mode-selector step that creates dead space above the partner row;
     let the content size to itself there. */
  .qbook__wizard :global(.min-h-\[400px\]) { min-height: 0; }

  @media (max-width: 760px) {
    .qbook { padding: 64px 20px; }
    .qbook__title { font-size: 34px; }
    .qbook__chips { grid-template-columns: 1fr; }
    .qbook__partner-row { gap: 28px; }
  }
</style>
