---
import { Picture } from 'astro:assets';
import { useTranslations } from '../../i18n/utils';
import guidePhoto from '../../images/guide-photo.webp';

const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section class="qguidebio">
  <div class="qguidebio__inner">
    <div class="qguidebio__photo">
      <Picture
        src={guidePhoto}
        alt="Clément Daguet-Schott, founder and guide of Paris History Tours"
        widths={[480, 720, 960, 1200]}
        sizes="(max-width: 900px) 100vw, 42vw"
        formats={["avif", "webp"]}
        quality={82}
        loading="eager"
        class="qguidebio__img"
      />
      <div class="qguidebio__badge">
        <div class="qguidebio__badge-stars" aria-hidden="true">★★★★★</div>
        <div class="qguidebio__badge-value">{t('quiet.about.guide.badgeValue')}</div>
        <div class="qguidebio__badge-label">{t('quiet.about.guide.badgeLabel')}</div>
      </div>
    </div>

    <div class="qguidebio__text">
      <p class="qguidebio__kicker">{t('quiet.about.guide.kicker')}</p>
      <h2 class="qguidebio__title">{t('quiet.about.guide.title')}</h2>

      <div class="qguidebio__body">
        <p>{t('keyFigures.guide.bio1')}</p>
        <p>{t('keyFigures.guide.bio2')}</p>
        <p>{t('keyFigures.guide.bio3')}</p>
      </div>

      <div class="qguidebio__stats">
        <div class="qguidebio__stat">
          <b>{t('quiet.about.guide.statBooksValue')}</b>
          <span>{t('quiet.about.guide.statBooksLabel')}</span>
        </div>
        <div class="qguidebio__stat">
          <b>{t('quiet.about.guide.statCountriesValue')}</b>
          <span>{t('quiet.about.guide.statCountriesLabel')}</span>
        </div>
        <div class="qguidebio__stat">
          <b>{t('quiet.about.guide.statRatingValue')}</b>
          <span>{t('quiet.about.guide.statRatingLabel')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .qguidebio {
    background: var(--paper);
    padding: 96px 32px;
  }
  .qguidebio__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 72px;
    align-items: start;
  }

  .qguidebio__photo {
    position: relative;
    aspect-ratio: 5 / 6;
    overflow: hidden;
    background: var(--paper-2);
  }
  .qguidebio__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% top;
    display: block;
  }
  .qguidebio__badge {
    position: absolute;
    bottom: 16px;
    right: 16px;
    background: var(--paper-3);
    border: 1px solid var(--border);
    padding: 14px 18px;
    min-width: 120px;
    text-align: left;
  }
  .qguidebio__badge-stars {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 4px;
  }
  .qguidebio__badge-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.1;
  }
  .qguidebio__badge-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-top: 4px;
  }

  .qguidebio__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0 0 16px;
  }
  .qguidebio__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 44px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 32px;
    line-height: 1.1;
  }
  .qguidebio__body p {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink);
    margin: 0 0 20px;
    max-width: 56ch;
  }
  .qguidebio__body p:last-child {
    color: var(--ink-2);
    margin-bottom: 0;
  }

  .qguidebio__stats {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .qguidebio__stat { display: flex; flex-direction: column; gap: 6px; }
  .qguidebio__stat b {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 32px;
    color: var(--ink);
    line-height: 1;
  }
  .qguidebio__stat span {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-2);
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .qguidebio { padding: 64px 24px; }
    .qguidebio__inner { grid-template-columns: 1fr; gap: 40px; }
    .qguidebio__title { font-size: 34px; }
    .qguidebio__photo { aspect-ratio: 3 / 2; max-width: 540px; }
  }
  @media (max-width: 600px) {
    .qguidebio__stats { grid-template-columns: 1fr; gap: 20px; }
    .qguidebio__stat b { font-size: 28px; }
  }
</style>
