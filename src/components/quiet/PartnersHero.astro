---
import { useTranslations } from '../../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section class="qpartnershero">
  <div class="qpartnershero__inner">
    <p class="qpartnershero__kicker">{t('quiet.partners.hero.kicker')}</p>
    <h1 class="qpartnershero__title">{t('quiet.partners.hero.title')}</h1>
    <p class="qpartnershero__subtitle">{t('quiet.partners.hero.subtitle')}</p>
  </div>
</section>

<style>
  .qpartnershero {
    background: var(--paper);
    padding: 96px 32px 72px;
    border-bottom: 1px solid var(--border);
  }
  .qpartnershero__inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .qpartnershero__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 20px;
  }
  .qpartnershero__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5.8vw, 68px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 22ch;
  }
  .qpartnershero__subtitle {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
    max-width: 64ch;
  }

  @media (max-width: 760px) {
    .qpartnershero { padding: 64px 20px 48px; }
    .qpartnershero__title { font-size: 36px; }
    .qpartnershero__subtitle { font-size: 15px; }
  }
</style>
