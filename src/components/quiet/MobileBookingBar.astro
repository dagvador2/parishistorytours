---
import { useTranslations } from '../../i18n/utils';

type Variant = 'default' | 'ww2' | 'general' | 'foodWine';

interface Props {
  href?: string;
  /** When rendered on a tour page, match the bar to that tour's price/duration.
   *  Homepage (default) keeps the lowest "from" price as an entry-point signal. */
  variant?: Variant;
}

const lang = Astro.locals.lang;
const t = useTranslations(lang);
const { href = '#book', variant = 'default' } = Astro.props;

const priceKey =
  variant === 'ww2'      ? 'quiet.mobileBooking.priceWW2'
  : variant === 'general'  ? 'quiet.mobileBooking.priceGeneral'
  : variant === 'foodWine' ? 'quiet.mobileBooking.priceFoodWine'
                           : 'quiet.mobileBooking.priceFrom';

const metaKey =
  variant === 'ww2'      ? 'quiet.mobileBooking.metaWW2'
  : variant === 'general'  ? 'quiet.mobileBooking.metaGeneral'
  : variant === 'foodWine' ? 'quiet.mobileBooking.metaFoodWine'
                           : 'quiet.mobileBooking.meta';
---

<div class="quiet-mbb">
  <div class="quiet-mbb__price">
    <b>{t(priceKey)}</b>
    <span>{t(metaKey)}</span>
  </div>
  <a href={href} class="quiet-mbb__cta">{t('quiet.mobileBooking.cta')}</a>
</div>

<style>
  .quiet-mbb {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 150;
    padding: 12px 16px calc(12px + env(safe-area-inset-bottom, 0px));
    background: var(--paper-3);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 12px -4px rgba(0, 0, 0, 0.08);
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--font-sans);
  }
  .quiet-mbb__price { line-height: 1.15; }
  .quiet-mbb__price b {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    color: var(--ink);
  }
  .quiet-mbb__price span {
    display: block;
    font-size: 11px;
    color: var(--ink-2);
    letter-spacing: 0.04em;
    margin-top: 2px;
  }
  .quiet-mbb__cta {
    padding: 14px 20px;
    background: var(--ink);
    color: var(--paper-3);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 2px;
    text-decoration: none;
    flex-shrink: 0;
    border: 1px solid var(--ink);
    transition: background 120ms ease, color 120ms ease;
  }
  .quiet-mbb__cta:hover {
    background: transparent;
    color: var(--ink);
  }

  @media (max-width: 760px) {
    .quiet-mbb { display: flex; }
  }
</style>
