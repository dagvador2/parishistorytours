---
import { useTranslations } from '../../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

interface Review {
  name: string;
  rating: number | null;
  text: string;
  source: string;
}

// Fetch live Google Place reviews server-side; fall back to empty grid on failure.
let reviews: Review[] = [];
let averageRating: number | null = null;
let totalReviews: number | null = null;
try {
  const res = await fetch(new URL('/api/google-reviews', Astro.url).toString());
  if (res.ok) {
    const json = await res.json();
    const raw: any[] = Array.isArray(json.reviews) ? json.reviews : [];
    reviews = raw
      .filter((r) => Number(r.rating) >= 5)
      .slice(0, 4)
      .map((r) => ({
        name: (r.name || 'Anonymous') as string,
        rating: (r.rating ?? null) as number | null,
        text: String(r.textBody || r.text || '').trim(),
        source: 'Google',
      }));
    if (typeof json.average_rating === 'number') averageRating = json.average_rating;
    if (typeof json.total === 'number') totalReviews = json.total;
  }
} catch {
  reviews = [];
}

// Graceful fallbacks — these values are also used in JSON-LD and have been stable
const displayRating = averageRating !== null ? averageRating.toFixed(1).replace('.', lang === 'fr' ? ',' : '.') : '4.9';
const displayTotal = totalReviews ?? 42;
const fullStars = Math.floor(averageRating ?? 4.9);
const fractional = (averageRating ?? 4.9) - fullStars;
---

{reviews.length > 0 && (
  <section id="reviews" class="qreviews">
    <div class="qreviews__inner">
      <header class="qreviews__header">
        <p class="qreviews__kicker">{t('quiet.home.reviews.kicker')}</p>
        <h2 class="qreviews__title">{t('quiet.home.reviews.title')}</h2>
      </header>

      <div class="qreviews__summary" aria-label={`Average rating ${displayRating} out of 5 based on ${displayTotal} reviews`}>
        <span class="qreviews__rating">{displayRating}</span>
        <span class="qreviews__summary-stars" aria-hidden="true">
          {Array.from({ length: 5 }).map((_, i) => {
            const fill = i < fullStars ? 1 : (i === fullStars ? fractional : 0);
            return (
              <span class="qreviews__summary-star">
                <span class="qreviews__summary-star-track">★</span>
                <span class="qreviews__summary-star-fill" style={`width:${Math.round(fill * 100)}%`}>★</span>
              </span>
            );
          })}
        </span>
        <span class="qreviews__summary-meta">Google · {displayTotal} {lang === 'fr' ? 'avis' : 'reviews'}</span>
      </div>

      <div class="qreviews__grid">
        {reviews.map((r) => (
          <figure class="qreviews__item">
            <blockquote class="qreviews__quote">
              "{r.text.length > 220 ? r.text.slice(0, 217).trimEnd() + '…' : r.text}"
            </blockquote>
            <div class="qreviews__stars" aria-label={`Rating ${r.rating ?? ''} of 5`}>
              {Array.from({ length: 5 }).map(() => <span aria-hidden="true">★</span>)}
            </div>
            <figcaption>
              <span class="qreviews__name">{r.name}</span>
              <span class="qreviews__source">{r.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .qreviews {
    background: var(--paper);
    padding: 96px 32px;
    border-top: 1px solid var(--border);
  }
  .qreviews__inner { max-width: 1280px; margin: 0 auto; }
  .qreviews__header { margin-bottom: 56px; }
  .qreviews__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0 0 16px;
  }
  .qreviews__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 48px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }

  .qreviews__summary {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    margin-bottom: 48px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .qreviews__rating {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 56px;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .qreviews__summary-stars {
    display: inline-flex;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1;
  }
  .qreviews__summary-star {
    position: relative;
    display: inline-block;
    color: var(--border);
  }
  .qreviews__summary-star-fill {
    position: absolute;
    left: 0; top: 0;
    overflow: hidden;
    color: var(--ink);
    white-space: nowrap;
  }
  .qreviews__summary-meta {
    margin-left: auto;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--ink-2);
  }

  .qreviews__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }
  .qreviews__item {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .qreviews__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
  }
  .qreviews__stars {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--ink);
    letter-spacing: 2px;
  }
  .qreviews__item figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-sans);
  }
  .qreviews__name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .qreviews__source {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  @media (max-width: 1100px) {
    .qreviews__grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }
  @media (max-width: 760px) {
    .qreviews { padding: 64px 0; }
    .qreviews__header,
    .qreviews__summary { margin-left: 20px; margin-right: 20px; }
    .qreviews__summary { flex-wrap: wrap; gap: 16px; }
    .qreviews__rating { font-size: 44px; }
    .qreviews__summary-stars { font-size: 22px; }
    .qreviews__summary-meta { margin-left: 0; width: 100%; }
    .qreviews__title { font-size: 34px; }
    .qreviews__grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 85%;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px 16px;
      scroll-padding: 0 20px;
    }
    .qreviews__grid::-webkit-scrollbar { display: none; }
    .qreviews__item {
      scroll-snap-align: start;
      background: var(--paper-3);
      border: 1px solid var(--border);
      padding: 24px;
      border-top: 1px solid var(--border);
    }
  }
</style>
