---
import { useTranslations } from '../../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const cards = [
  {
    numeral: 'I',
    title: t('quiet.about.building.booksTitle'),
    desc: t('quiet.about.building.booksDesc'),
  },
  {
    numeral: 'II',
    title: t('quiet.about.building.monthsTitle'),
    desc: t('quiet.about.building.monthsDesc'),
  },
  {
    numeral: 'III',
    title: t('quiet.about.building.themesTitle'),
    desc: t('quiet.about.building.themesDesc'),
  },
];
---

<section class="qbuilding">
  <div class="qbuilding__inner">
    <header class="qbuilding__head">
      <p class="qbuilding__kicker">{t('quiet.about.building.kicker')}</p>
      <h2 class="qbuilding__title">{t('quiet.about.building.title')}</h2>
      <p class="qbuilding__subtitle">{t('quiet.about.building.subtitle')}</p>
    </header>

    <div class="qbuilding__grid">
      <div class="qbuilding__photo">
        <img
          src="/photos/book_ww2_guide_paris.webp"
          alt="Historical research books used for tour preparation"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="qbuilding__cards">
        {cards.map((c) => (
          <article class="qbuilding__card">
            <span class="qbuilding__numeral" aria-hidden="true">{c.numeral}</span>
            <div class="qbuilding__card-body">
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .qbuilding {
    background: var(--paper-2);
    padding: 96px 32px;
  }
  .qbuilding__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .qbuilding__head {
    max-width: 640px;
    margin: 0 0 56px;
  }
  .qbuilding__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qbuilding__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(34px, 4.4vw, 48px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .qbuilding__subtitle {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }

  .qbuilding__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: stretch;
  }
  .qbuilding__photo {
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
    min-height: 100%;
  }
  .qbuilding__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .qbuilding__cards {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0;
    min-height: 520px;
  }
  .qbuilding__card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 28px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
    align-items: center;
    flex: 1;
  }
  .qbuilding__card:first-child { padding-top: 0; }
  .qbuilding__card:last-child { border-bottom: none; padding-bottom: 0; }

  .qbuilding__numeral {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    background: var(--paper-3);
    border: 1px solid var(--border);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .qbuilding__card-body h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 26px;
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .qbuilding__card-body p {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
  }

  @media (max-width: 900px) {
    .qbuilding { padding: 64px 24px; }
    .qbuilding__grid { grid-template-columns: 1fr; gap: 32px; }
    .qbuilding__photo { aspect-ratio: 3 / 2; min-height: auto; max-width: 540px; }
    .qbuilding__cards { min-height: auto; }
    .qbuilding__card { flex: none; padding: 24px 0; align-items: start; }
  }
  @media (max-width: 600px) {
    .qbuilding__card { gap: 20px; padding: 24px 0; }
    .qbuilding__card-body h3 { font-size: 22px; }
  }
</style>
