---
import { useTranslations } from '../../i18n/utils';

interface RelatedPost {
  id: string;
  data: {
    title: string;
    description: string;
    publishDate: Date;
    image?: string;
    imageAlt?: string;
    tags: string[];
  };
}

interface Props {
  posts: RelatedPost[];
  langPrefix: string;
}

const { posts, langPrefix } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
const dateLocale = lang === 'fr' ? 'fr-FR' : 'en-US';
const fmtDate = (d: Date) => d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

{posts.length > 0 && (
  <section class="qarrel">
    <div class="qarrel__inner">
      <header class="qarrel__head">
        <p class="qarrel__kicker">{t('quiet.blog.relatedKicker')}</p>
        <h2 class="qarrel__title">{t('quiet.blog.relatedHeading')}</h2>
      </header>
      <div class="qarrel__grid">
        {posts.map((post) => (
          <a href={`${langPrefix}/blog/${post.id}`} class="qarrel__card">
            {post.data.image && (
              <div class="qarrel__img">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" decoding="async" />
              </div>
            )}
            <div class="qarrel__body">
              <time class="qarrel__date" datetime={post.data.publishDate.toISOString()}>{fmtDate(post.data.publishDate)}</time>
              <h3 class="qarrel__card-title">{post.data.title}</h3>
              <p class="qarrel__desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .qarrel {
    background: var(--paper);
    padding: 80px 32px;
  }
  .qarrel__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .qarrel__head {
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .qarrel__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qarrel__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 36px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }
  .qarrel__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .qarrel__card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
  }
  .qarrel__card:hover .qarrel__card-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .qarrel__card:hover .qarrel__img img { transform: scale(1.02); }
  .qarrel__img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
  }
  .qarrel__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .qarrel__date {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    display: block;
    margin-bottom: 10px;
  }
  .qarrel__card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .qarrel__desc {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .qarrel__grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 760px) {
    .qarrel { padding: 56px 20px; }
    .qarrel__title { font-size: 28px; }
  }
</style>
