---
import { useTranslations } from '../../i18n/utils';
import type { GalleryImage } from '../../data/tours';

interface Props {
  images: GalleryImage[];
  photoCredit?: { handle: string; url: string };
}

const { images, photoCredit } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
const creditLabel = lang === 'fr' ? 'Photographies' : 'Photography';
---

<section class="qgal">
  <div class="qgal__inner">
    <header class="qgal__header">
      <p class="qgal__kicker">{t('quiet.tour.gallery.kicker')}</p>
      <h2 class="qgal__title">{t('quiet.tour.gallery.title')}</h2>
    </header>

    <div class="qgal__grid">
      {images.map((img) => (
        <figure class="qgal__item">
          <div class="qgal__frame">
            <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
          </div>
          {img.caption && <figcaption>{img.caption}</figcaption>}
        </figure>
      ))}
    </div>

    {photoCredit && (
      <p class="qgal__credit">
        {creditLabel} · <a href={photoCredit.url} target="_blank" rel="noopener">{photoCredit.handle}</a>
      </p>
    )}
  </div>
</section>

<style>
  .qgal { background: var(--paper); padding: 96px 32px; }
  .qgal__inner { max-width: 1280px; margin: 0 auto; }
  .qgal__header { margin-bottom: 56px; max-width: 720px; }
  .qgal__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qgal__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 52px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }

  .qgal__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .qgal__item { margin: 0; }
  .qgal__frame {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid var(--border);
  }
  .qgal__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .qgal__item:hover .qgal__frame img { transform: scale(1.03); }
  .qgal__item figcaption {
    margin-top: 10px;
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.5;
    color: var(--ink-2);
    letter-spacing: 0.02em;
  }

  .qgal__credit {
    margin: 32px 0 0;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-2);
    text-align: center;
  }
  .qgal__credit a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    transition: border-color 120ms ease;
  }
  .qgal__credit a:hover { border-bottom-color: var(--ink); }

  @media (max-width: 900px) {
    .qgal { padding: 64px 0; }
    .qgal__header { padding: 0 24px; }
    .qgal__grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 72%;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 24px 16px;
      scroll-padding: 0 24px;
    }
    .qgal__grid::-webkit-scrollbar { display: none; }
    .qgal__item { scroll-snap-align: start; }
  }
</style>
