---
import { useTranslations } from '../../i18n/utils';

interface Props {
  authorLink: string;
}

const { authorLink } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<aside class="qarauth">
  <div class="qarauth__inner">
    <p class="qarauth__kicker">{t('quiet.blog.authorKicker')}</p>
    <div class="qarauth__body">
      <img
        src="/photos/left_bank/Paris_WW2_guide.webp"
        alt="Clément Daguet-Schott"
        width="96"
        height="96"
        class="qarauth__photo"
        loading="lazy"
      />
      <div class="qarauth__text">
        <p class="qarauth__name">Clément Daguet-Schott</p>
        <p class="qarauth__bio">{t('quiet.blog.authorBio')}</p>
        <a href={authorLink} class="qarauth__link">
          {t('quiet.blog.authorLink')} <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</aside>

<style>
  .qarauth {
    background: var(--paper);
    padding: 48px 32px;
    border-top: 1px solid var(--border);
  }
  .qarauth__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .qarauth__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0 0 20px;
  }
  .qarauth__body {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .qarauth__photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    object-position: 60% top;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .qarauth__text { flex: 1; min-width: 0; }
  .qarauth__name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.2;
  }
  .qarauth__bio {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 14px;
    max-width: 52ch;
  }
  .qarauth__link {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .qarauth__link:hover { text-decoration: underline; text-underline-offset: 3px; }
  .qarauth__link span { transition: transform 160ms ease; }
  .qarauth__link:hover span { transform: translateX(4px); }

  @media (max-width: 600px) {
    .qarauth { padding: 40px 20px; }
    .qarauth__body { flex-direction: column; gap: 20px; }
  }
</style>
