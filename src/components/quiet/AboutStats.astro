---
import { useTranslations } from '../../i18n/utils';
import WorldMap from '../WorldMap.tsx';

interface Stat { label: string; value: number; }
interface CountryItem { country: string; count: number; code: string; percentage: number; }

interface Props {
  stats: Stat[];
  topCountries: CountryItem[];
  worldMapData: Record<string, number>;
  worldMapMax: number;
}

const { stats, topCountries, worldMapData, worldMapMax } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section class="qstats">
  <div class="qstats__inner">
    <header class="qstats__head">
      <p class="qstats__kicker">{t('quiet.about.stats.kicker')}</p>
      <h2 class="qstats__title">{t('quiet.about.stats.title')}</h2>
      <p class="qstats__subtitle">{t('quiet.about.stats.subtitle')}</p>
    </header>

    <div class="qstats__cards q-stat-root">
      {stats.map((stat) => (
        <div class="qstats__card">
          <b class="q-stat-number" data-target={stat.value}>0</b>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>

    <!-- AI-readable copy -->
    <div class="sr-only">
      <p>{lang === 'fr'
        ? 'Chiffres clés de Paris History Tours : plus de 300 participants venus de plus de 25 pays à travers plus de 60 visites guidées, couvrant plus de 150 kilomètres de parcours pédestres dans le Paris historique. Les visiteurs viennent des États-Unis, du Royaume-Uni, d\'Allemagne, de France, du Canada, d\'Australie, d\'Espagne et de nombreux autres pays. Fondé en 2024, Paris History Tours maintient une note de 4.9 sur 5 étoiles avec plus de 42 avis Google.'
        : 'Paris History Tours key statistics: over 300 participants from 25+ countries across 60+ guided tours, covering more than 150 kilometers of walking tours through historic Paris. Visitors come from the United States, United Kingdom, Germany, France, Canada, Australia, Spain, and many more countries. Founded in 2024, Paris History Tours has maintained a 4.9 out of 5 star rating across 42+ Google reviews.'
      }</p>
    </div>

    <div class="qstats__split">
      <div class="qstats__panel">
        <h3 class="qstats__panel-title">{t('quiet.about.stats.topCountries')}</h3>
        <ul class="qstats__bars q-bars-root">
          {topCountries.map((item, i) => (
            <li class="qstats__bar-row">
              <span class="qstats__bar-rank">{String(i + 1).padStart(2, '0')}</span>
              <span class="qstats__bar-flag">
                <img
                  src={`https://flagsapi.com/${item.code}/flat/64.png`}
                  alt={`${item.country} flag`}
                  loading="lazy"
                />
              </span>
              <span class="qstats__bar-country">{item.country}</span>
              <span class="qstats__bar-track">
                <span class="qstats__bar-fill q-bar-fill" style="width: 0%;" data-width={`${item.percentage}%`}></span>
              </span>
              <span class="qstats__bar-count">
                <b>{item.count}</b>
                <span>pax</span>
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="qstats__panel qstats__panel--map">
        <WorldMap client:visible countryData={worldMapData} maxValue={worldMapMax} theme="quiet" />
      </div>
    </div>
  </div>
</section>

<style>
  .qstats {
    background: var(--paper);
    padding: 96px 32px;
  }
  .qstats__inner { max-width: 1280px; margin: 0 auto; }
  .qstats__head {
    max-width: 640px;
    margin: 0 auto 56px;
    text-align: center;
  }
  .qstats__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qstats__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(34px, 4.4vw, 48px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .qstats__subtitle {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }

  .qstats__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    background: var(--paper-3);
  }
  .qstats__card {
    padding: 32px 24px;
    text-align: left;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .qstats__card:last-child { border-right: none; }
  .qstats__card b {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 48px);
    color: var(--ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .qstats__card span {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    line-height: 1.3;
  }

  .qstats__split {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: stretch;
  }
  .qstats__panel {
    background: var(--paper-3);
    border: 1px solid var(--border);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
  }
  .qstats__panel--map {
    padding: 0;
  }
  .qstats__panel--map :global(> div) {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .qstats__panel-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .qstats__bars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    gap: 12px;
    flex: 1;
  }
  .qstats__bar-row {
    display: grid;
    grid-template-columns: 28px 32px minmax(90px, 1fr) 1.6fr auto;
    gap: 12px;
    align-items: center;
  }
  .qstats__bar-rank {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--ink-2);
  }
  .qstats__bar-flag {
    width: 28px;
    height: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    display: block;
  }
  .qstats__bar-flag img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .qstats__bar-country {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .qstats__bar-track {
    height: 6px;
    background: var(--paper-2);
    border-radius: 0;
    position: relative;
    overflow: hidden;
  }
  .qstats__bar-fill {
    display: block;
    height: 100%;
    background: var(--ink);
    transition: width 900ms ease-out;
  }
  .qstats__bar-count {
    font-family: var(--font-sans);
    text-align: right;
    white-space: nowrap;
  }
  .qstats__bar-count b {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 15px;
    color: var(--ink);
  }
  .qstats__bar-count span {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-left: 4px;
  }

  @media (max-width: 900px) {
    .qstats { padding: 64px 20px; }
    .qstats__cards { grid-template-columns: repeat(2, 1fr); }
    .qstats__card:nth-child(2) { border-right: none; }
    .qstats__card:nth-child(1),
    .qstats__card:nth-child(2) { border-bottom: 1px solid var(--border); }
    .qstats__card:nth-child(3) { border-right: 1px solid var(--border); }
    .qstats__split { grid-template-columns: 1fr; }
    .qstats__panel { padding: 24px; min-height: auto; }
  }
  @media (max-width: 600px) {
    .qstats__bar-row { grid-template-columns: 24px 28px minmax(80px, 1fr) 1fr auto; gap: 8px; }
    .qstats__bar-country { font-size: 12px; }
  }
</style>

<script>
  // Number ticker + bar animation via IntersectionObserver
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const root = entry.target as HTMLElement;

      root.querySelectorAll<HTMLElement>('.q-stat-number').forEach((el) => {
        const target = parseInt(el.dataset.target || '0', 10);
        if (!target) return;
        const duration = 1500;
        const start = performance.now();
        const locale = document.documentElement.lang === 'fr' ? 'fr-FR' : 'en-US';
        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target).toLocaleString(locale);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });

      root.querySelectorAll<HTMLElement>('.q-bar-fill').forEach((el, i) => {
        const w = el.dataset.width || '0%';
        setTimeout(() => { el.style.width = w; }, 200 + i * 100);
      });

      observer.unobserve(entry.target);
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.q-stat-root, .q-bars-root').forEach((el) => observer.observe(el));
</script>
