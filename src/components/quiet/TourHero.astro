---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  kicker: string;
  title: string;
  subtitle: string;
}

const { image, alt, kicker, title, subtitle } = Astro.props;
---

<section class="qtourhero">
  <Picture
    src={image}
    alt={alt}
    widths={[640, 960, 1280, 1800, 2400]}
    sizes="100vw"
    formats={["avif", "webp"]}
    loading="eager"
    quality={82}
    class="qtourhero__img"
  />
  <div class="qtourhero__scrim"></div>
  <div class="qtourhero__content">
    <p class="qtourhero__kicker">{kicker}</p>
    <h1 class="qtourhero__title">{title}</h1>
    {subtitle && <p class="qtourhero__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .qtourhero {
    position: relative;
    width: 100%;
    height: min(80vh, 760px);
    overflow: hidden;
    background: var(--ink);
  }
  .qtourhero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .qtourhero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0.25) 50%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }
  .qtourhero__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 48px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    color: var(--paper-3);
  }
  .qtourhero__kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 20px;
  }
  .qtourhero__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 18ch;
    color: var(--paper-3);
  }
  .qtourhero__subtitle {
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    margin: 20px 0 0;
    max-width: 56ch;
  }

  @media (max-width: 760px) {
    .qtourhero { height: 68vh; }
    .qtourhero__content { bottom: 36px; padding: 0 20px; }
    .qtourhero__subtitle { font-size: 15px; }
  }
</style>
