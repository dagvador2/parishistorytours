---
import { Picture } from 'astro:assets';
import { useTranslations } from '../../i18n/utils';
import notreDame from '../../images/notre-dame-de-paris.webp';
import bridge from '../../images/bridge_alexander_third_paris.webp';
import vendome from '../../images/place_vendome_paris_day.webp';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const stats = [
  { value: t('quiet.home.hero.statToursValue'),     label: t('quiet.home.hero.statToursLabel') },
  { value: t('quiet.home.hero.statYearsValue'),     label: t('quiet.home.hero.statYearsLabel') },
  { value: t('quiet.home.hero.statCountriesValue'), label: t('quiet.home.hero.statCountriesLabel') },
  { value: t('quiet.home.hero.statRatingValue'),    label: t('quiet.home.hero.statRatingLabel') },
  { value: t('quiet.home.hero.statGroupValue'),     label: t('quiet.home.hero.statGroupLabel') },
];
---

<section class="qhero">
  <div class="qhero__inner">
    <div class="qhero__tag">{t('quiet.home.hero.posterTag')}</div>

    <h1 class="qhero__headline">
      {t('quiet.home.hero.headlinePart1')}
      <span class="qhero__accent"> {t('quiet.home.hero.headlineAccent')} </span>
      <span class="qhero__small">{t('quiet.home.hero.headlinePart2')}</span>
      {t('quiet.home.hero.headlinePart3')}
    </h1>

    <p class="qhero__lede">{t('quiet.home.hero.lede')}</p>

    <div class="qhero__cta-row">
      <a href="#tours" class="qhero__btn qhero__btn--primary">{t('quiet.home.hero.browseCta')} <span aria-hidden="true">→</span></a>
      <a href="#route" class="qhero__btn qhero__btn--ghost">{t('quiet.home.hero.seeRouteCta')}</a>
    </div>

    <div class="qhero__media">
      <figure class="qhero__media-main">
        <Picture src={notreDame} alt={t('quiet.home.hero.mediaMainAlt')} widths={[640, 960, 1280]} sizes="(max-width:900px) 100vw, 50vw" formats={["avif","webp"]} quality={82} loading="eager" class="qhero__img" />
        <figcaption><b>{t('quiet.home.hero.mediaMainLabel')}</b>{t('quiet.home.hero.mediaMainCaption')}</figcaption>
      </figure>
      <figure class="qhero__media-side">
        <Picture src={bridge} alt={t('quiet.home.hero.mediaSideAAlt')} widths={[400, 640, 800]} sizes="(max-width:900px) 50vw, 25vw" formats={["avif","webp"]} quality={80} loading="lazy" class="qhero__img" />
        <figcaption><b>{t('quiet.home.hero.mediaSideALabel')}</b>{t('quiet.home.hero.mediaSideACaption')}</figcaption>
      </figure>
      <figure class="qhero__media-side">
        <Picture src={vendome} alt={t('quiet.home.hero.mediaSideBAlt')} widths={[400, 640, 800]} sizes="(max-width:900px) 50vw, 25vw" formats={["avif","webp"]} quality={80} loading="lazy" class="qhero__img" />
        <figcaption><b>{t('quiet.home.hero.mediaSideBLabel')}</b>{t('quiet.home.hero.mediaSideBCaption')}</figcaption>
      </figure>
    </div>

    <div class="qhero__stats">
      {stats.map((s) => (
        <div class="qhero__stat">
          <b>{s.value}</b>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .qhero {
    background: var(--paper);
    padding: 64px 32px 96px;
  }
  .qhero__inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .qhero__tag {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rouge);
    margin-bottom: 28px;
  }
  .qhero__tag::before,
  .qhero__tag::after {
    content: "";
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--ink);
    opacity: 0.3;
  }

  .qhero__headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 7.2vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 16ch;
    margin: 0 auto;
  }
  .qhero__accent {
    color: var(--rouge);
    font-style: italic;
    font-weight: 500;
  }
  .qhero__small {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: 0.5em;
    color: var(--ink-2);
    letter-spacing: 0;
    line-height: 1.3;
    margin: 14px 0 4px;
    max-width: 34ch;
    margin-left: auto;
    margin-right: auto;
  }

  .qhero__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 62ch;
    margin: 32px auto 28px;
  }
  .qhero__lede::first-letter {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
    font-size: 3.2em;
    float: left;
    line-height: 0.9;
    padding: 6px 12px 0 0;
  }

  .qhero__cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }
  .qhero__btn {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 14px 24px;
    border-radius: 2px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    border: 1px solid var(--ink);
  }
  .qhero__btn--primary { background: var(--ink); color: var(--paper-3); }
  .qhero__btn--primary:hover { background: var(--rouge); border-color: var(--rouge); }
  .qhero__btn--ghost { background: transparent; color: var(--ink); }
  .qhero__btn--ghost:hover { background: var(--ink); color: var(--paper-3); }

  .qhero__media {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: repeat(2, 1fr);
    gap: 16px;
    aspect-ratio: 16 / 9;
    margin: 48px 0;
    text-align: left;
  }
  .qhero__media-main {
    grid-row: span 2;
    margin: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--paper-2);
  }
  .qhero__media-side {
    margin: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--paper-2);
  }
  .qhero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .qhero__media figure:hover .qhero__img { transform: scale(1.03); }
  .qhero__media figcaption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 14px 16px 12px;
    background: linear-gradient(to top, rgba(26,26,26,0.72), rgba(26,26,26,0));
    color: var(--paper-3);
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: 0.02em;
  }
  .qhero__media figcaption b {
    display: block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 15px;
    margin-bottom: 2px;
    letter-spacing: 0;
  }

  .qhero__stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    max-width: 880px;
    margin: 8px auto 0;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .qhero__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 16px;
    border-right: 1px solid var(--border);
  }
  .qhero__stat:last-child { border-right: 0; }
  .qhero__stat b {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 32px;
    color: var(--ink);
    line-height: 1;
  }
  .qhero__stat span {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-2);
  }

  @media (max-width: 900px) {
    .qhero { padding: 48px 20px 72px; }
    .qhero__media {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      aspect-ratio: auto;
    }
    .qhero__media-main { grid-row: auto; grid-column: span 2; aspect-ratio: 4/3; }
    .qhero__media-side { aspect-ratio: 1/1; }
    .qhero__stats { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .qhero__stat { border-right: none; border-bottom: 1px solid var(--border); padding-bottom: 16px; }
    .qhero__stat:nth-child(n+3) { border-bottom: 0; }
    .qhero__lede { font-size: 17px; }
    .qhero__lede::first-letter { font-size: 2.8em; }
  }
</style>
