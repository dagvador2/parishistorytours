---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import { useTranslations } from '../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const {
  title = "Paris History Tours",
  description = "WWII walking tours in Paris: Right Bank and Left Bank routes exploring the Fall, Resistance, and Liberation.",
  ogImage = "/photos/left_bank/Paris_WW2_guide.webp",
  ogType = "website",
  noindex = false,
  preloadImages = [] as Array<string | { srcset: string; sizes: string }>,
} = Astro.props;

const origin = Astro.url.origin;
const pathname = Astro.url.pathname;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${origin}${ogImage}`;
// Compute base path (without /fr prefix) for hreflang - works with both direct and rewritten URLs
const basePath = pathname.startsWith('/fr') ? (pathname.replace(/^\/fr/, '') || '/') : pathname;
const enPath = basePath;
const frPath = basePath === '/' ? '/fr' : `/fr${basePath}`;
const canonicalUrl = lang === 'fr' ? `${origin}${frPath}` : `${origin}${enPath}`;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-K6M2KKL7');</script>
<!-- End Google Tag Manager -->
 <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-26695P8H33"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-26695P8H33');
</script>
    <meta charset="utf-8" />
    <!-- Fallback for some analyzers expecting http-equiv -->
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={`${origin}${enPath}`} />
    <link rel="alternate" hreflang="fr" href={`${origin}${frPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${origin}${enPath}`} />
    <!-- Favicon and icons -->
    <link rel="icon" href="/favicon.ico" type="image/x-icon"/>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Paris History Tours" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'fr' ? 'en_US' : 'fr_FR'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Noindex for non-content pages -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <!-- Self-hosted Montserrat — preload latin subset -->
    <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />
    {preloadImages.map((img) =>
      typeof img === 'string'
        ? <link rel="preload" as="image" href={img} />
        : <link rel="preload" as="image" imagesrcset={img.srcset} imagesizes={img.sizes} />
    )}
  </head>

  <body class="font-sans text-gray-900 antialiased">
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K6M2KKL7"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
    <slot />
    <Footer />
  </body>
</html>