---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'fr');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const canonicalUrl = `https://www.parishistorytours.com/fr/blog/${post.id}`;
const imageUrl = post.data.image ? `https://www.parishistorytours.com${post.data.image}` : undefined;
---

<BaseLayout
  title={`${post.data.title} | Paris History Tours`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <Breadcrumbs items={[
    { label: t('nav.home'), href: '/fr/' },
    { label: 'Blog', href: '/fr/blog' },
    { label: post.data.title }
  ]} />

  <main class="min-h-screen bg-white py-12">
    <article class="max-w-3xl mx-auto px-4">
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt || post.data.title}
          class="w-full h-64 md:h-96 object-cover rounded-xl mb-8"
          loading="eager"
        />
      )}

      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 text-gray-600">
          <span>{post.data.author}</span>
          <span>|</span>
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      </header>

      <div class="prose prose-lg prose-gray max-w-none">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 p-8 bg-gray-50 rounded-xl text-center">
        <h2 class="text-2xl font-bold text-gray-800 mb-3">
          Envie de découvrir ces lieux en personne ?
        </h2>
        <p class="text-gray-600 mb-6">
          Rejoignez notre visite guidée de 2 heures à pied dans le Paris de la Seconde Guerre mondiale.
        </p>
        <a href="/fr/#book-tour"
           class="inline-block bg-gray-800 text-white px-8 py-3 rounded-lg hover:bg-gray-700 transition font-medium">
          {t('common.bookNow')}
        </a>
      </div>
    </article>
  </main>

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "author": {
      "@type": "Person",
      "name": "Clement Daguet-Schott",
      "url": "https://www.parishistorytours.com/key-figures"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Paris History Tours",
      "url": "https://www.parishistorytours.com"
    },
    "datePublished": post.data.publishDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.publishDate).toISOString(),
    "mainEntityOfPage": canonicalUrl,
    ...(imageUrl ? { "image": imageUrl } : {}),
    "inLanguage": "fr"
  }} />
</BaseLayout>
