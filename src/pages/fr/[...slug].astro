---
// This catch-all route handles all /fr/* paths and routes them to the same content
// as the English versions, but with French translations

import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const blogPaths = posts.map((post) => ({
    params: { slug: `blog/${post.id}` },
  }));

  return [
    // Homepage
    { params: { slug: undefined } },

    // Tour pages
    { params: { slug: 'tours/left-bank' } },
    { params: { slug: 'tours/right-bank' } },
    { params: { slug: 'tours/general-history' } },

    // Other pages
    { params: { slug: 'key-figures' } },
    { params: { slug: 'success' } },

    // Blog
    { params: { slug: 'blog' } },
    ...blogPaths,
  ];
}

const { slug } = Astro.params;

// Rewrite all /fr/* paths to their EN equivalents (translations handled via Astro.locals.lang)
if (!slug) {
  return Astro.rewrite('/');
} else if (slug === 'blog' || slug?.startsWith('blog/')) {
  return Astro.rewrite(`/${slug}`);
} else {
  return Astro.rewrite(`/${slug}`);
}
---
