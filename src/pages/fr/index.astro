---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Welcome from "../../components/Welcome.astro";
import ToursAvailable from "../../components/ToursAvailable.astro";
import Reviews from "../../components/Reviews.astro";
import BookTour from "../../components/BookTour.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import "../../styles/global.css";
import { useTranslations } from '../../i18n/utils';

import JsonLd from "../../components/JsonLd.astro";
import FAQ from "../../components/FAQ.astro";
import LocationCarousel from "../../components/ui/LocationCarousel.tsx";
import { AuroraBackground } from "../../components/ui/aurora-background.tsx";

const lang = Astro.locals.lang;
const t = useTranslations(lang);

// Create language-aware navigation links
const langPrefix = '/fr';
---

<BaseLayout title={t('meta.home.title')} description={t('meta.home.description')} ogImage="/photos/left_bank/Paris_WW2_guide.webp">
	<!-- Bannière de navigation fixe pour desktop -->
	<nav class="fixed top-0 left-0 w-full bg-white border-b border-gray-300 z-[9999] shadow-md hidden md:block">
		<div class="max-w-5xl mx-auto flex items-center justify-between py-4 px-6">
			<div class="flex items-center gap-8 flex-1 justify-center">
				<a href={`${langPrefix}/tours/left-bank`} class="text-gray-800 font-semibold hover:text-blue-600 transition-colors duration-200 px-4 py-2 rounded-md hover:bg-gray-50">{t('nav.leftBank')}</a>
				<a href={`${langPrefix}/tours/right-bank`} class="text-gray-800 font-semibold hover:text-blue-600 transition-colors duration-200 px-4 py-2 rounded-md hover:bg-gray-50">{t('nav.rightBank')}</a>
				<a href={langPrefix} class="text-gray-800 font-semibold hover:text-blue-600 transition-colors duration-200 px-4 py-2 rounded-md hover:bg-gray-50">{t('nav.home')}</a>
			</div>
			<LanguageSwitcher />
		</div>
	</nav>

	<!-- Menu mobile hamburger -->
	<div class="md:hidden fixed top-4 right-4 z-50">
		<button id="mobile-menu-btn" class="bg-white/90 backdrop-blur-sm border border-gray-200 rounded-lg p-3 shadow-lg hover:bg-white transition-all duration-200">
			<svg id="hamburger-icon" class="w-6 h-6 text-gray-800 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
			</svg>
			<svg id="close-icon" class="hidden w-6 h-6 text-gray-800 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>

		<!-- Menu déroulant mobile -->
		<div id="mobile-menu" class="hidden absolute top-14 right-0 bg-white border border-gray-200 rounded-lg shadow-xl py-2 min-w-48 opacity-0 transition-all duration-200 transform scale-95">
			<a href="#about" class="mobile-menu-item block px-4 py-3 text-gray-800 hover:bg-gray-50 border-b border-gray-100 font-medium">{t('nav.presentation')}</a>
			<a href="#tours" class="mobile-menu-item block px-4 py-3 text-gray-800 hover:bg-gray-50 border-b border-gray-100 font-medium">{t('nav.toursAvailable')}</a>
			<a href="#reviews" class="mobile-menu-item block px-4 py-3 text-gray-800 hover:bg-gray-50 border-b border-gray-100 font-medium">{t('nav.reviews')}</a>
			<a href="#book-tour" class="mobile-menu-item block px-4 py-3 text-gray-800 hover:bg-gray-50 border-b border-gray-100 font-medium">{t('nav.bookTour')}</a>
			<a href="#gallery" class="mobile-menu-item block px-4 py-3 text-gray-800 hover:bg-gray-50 font-medium">{t('nav.gallery')}</a>
		</div>
	</div>

	<!-- Hero section -->
	<section id="about" class="relative max-w-full text-lg leading-8 min-h-screen" style="font-family: 'Montserrat', Inter, system-ui, sans-serif;">
		{/* Aurora background — rendered as a fixed visual layer behind all content */}
		<div class="absolute inset-0 z-0">
			<AuroraBackground client:only="react" className="min-h-full" />
		</div>

		{/* Page content — rendered server-side as normal Astro HTML */}
		<div class="relative z-10 py-8 md:py-24 md:pt-40 px-2">
		{/* Titre principal et sous-titre */}
		<div class="max-w-4xl mx-auto flex flex-col items-center justify-center mb-0">
			<h1 class="text-4xl md:text-6xl font-bold text-center text-gray-800 m-0 p-0 mb-4">
				{t('home.title')}
			</h1>
			<div class="w-16 h-px bg-gray-400 mb-4"></div>
			<h2 class="text-xl md:text-2xl font-medium text-center text-gray-600 m-0 p-0">
				{t('home.subtitle')}
			</h2>
		</div>

		{/* Hero gallery — Full-width location carousel */}
		<div class="max-w-5xl mx-auto mt-8 mb-4 px-4">
			<LocationCarousel
				client:only="react"
				cardsPerView={3}
				autoPlayMs={4000}
				height="30rem"
				cards={[
					{
						imgUrl: '/photos/left_bank/luxembourg_palace_paris.webp',
						title: t('home.gallery.pantheon.title'),
						subtitle: 'Visite Rive Gauche — Arrêt 2',
						description: t('home.gallery.pantheon.description') + ' Le Palais du Luxembourg a servi de quartier général de la Luftwaffe pendant les 4 années d\'occupation nazie de Paris.',
						tag: 'Visite Rive Gauche',
					},
					{
						imgUrl: '/photos/right_bank/place_vendome_paris_day.webp',
						title: t('home.gallery.placeVendome.title'),
						subtitle: 'Visite Rive Droite — Arrêt 4',
						description: t('home.gallery.placeVendome.description') + ' C\'est ici qu\'Ernest Hemingway est arrivé pour "libérer" le bar du Ritz le 25 août 1944.',
						tag: 'Visite Rive Droite',
					},
					{
						imgUrl: '/photos/left_bank/notre-dame-de-paris.webp',
						title: 'Notre-Dame de Paris',
						subtitle: 'Visite Rive Gauche — Arrêt 4',
						description: "Témoin de la Libération de Paris en août 1944. Le général de Gaulle y a mené une marche victorieuse malgré des tirs de snipers actifs le long du parcours.",
						tag: 'Visite Rive Gauche',
					},
					{
						imgUrl: '/photos/right_bank/bridge_alexander_third_paris.webp',
						title: 'Pont Alexandre III',
						subtitle: 'Visite Rive Droite — Arrêt 1',
						description: "Un des ponts qu'Hitler a ordonné de détruire avant l'avancée alliée. Il a survécu grâce à la décision de la garnison allemande de désobéir à l'ordre de démolition.",
						tag: 'Visite Rive Droite',
					},
					{
						imgUrl: '/photos/right_bank/place_concorde_paris.webp',
						title: 'Place de la Concorde',
						subtitle: 'Visite Rive Droite — Arrêt 3',
						description: t('home.gallery.jeuDePaume.description') + " Le site du premier drapeau français hissé sur un bâtiment public lors de la Libération, remplaçant la croix gammée.",
						tag: 'Visite Rive Droite',
					},
				]}
			/>
		</div>

		<div class="flex justify-center mb-8">
			<div class="w-32 h-1 bg-gray-400 rounded-full"></div>
		</div>

		<Welcome />
		<ToursAvailable />
		<Reviews />

		<!-- Social Proof / Trust Signals -->
		<section class="py-12 bg-white/60 backdrop-blur-sm rounded-2xl mx-4 my-8">
			<div class="max-w-4xl mx-auto px-4 text-center">
				<h2 class="text-2xl font-bold text-gray-800 mb-6">{t('socialProof.title')}</h2>
				<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">4.9/5</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.googleRating')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">40+</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.reviews')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">25+</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.countries')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">2024</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.founded')}</div>
					</div>
				</div>
				<p class="mt-8 text-gray-600 text-lg">{t('socialProof.description')}</p>
			</div>
		</section>

		<BookTour />
		<FAQ />
		</div>
	</section>

	<JsonLd data={{
		"@context": "https://schema.org",
		"@type": ["LocalBusiness", "TravelAgency"],
		"name": "Paris History Tours",
		"alternateName": "Paris History Tours - Visites guidées Seconde Guerre mondiale à Paris",
		"description": t('meta.home.description'),
		"url": "https://www.parishistorytours.com",
		"telephone": "+33620622480",
		"email": "clemdaguetschott@gmail.com",
		"foundingDate": "2024",
		"slogan": "Découvrez Paris à travers les yeux de la Seconde Guerre mondiale",
		"knowsLanguage": ["en", "fr"],
		"currenciesAccepted": "EUR",
		"paymentAccepted": "Credit Card, Stripe",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Paris",
			"addressRegion": "Ile-de-France",
			"addressCountry": "FR"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 48.8566,
			"longitude": 2.3522
		},
		"image": "https://www.parishistorytours.com/photos/left_bank/Paris_WW2_guide.webp",
		"priceRange": "$$",
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": "4.9",
			"bestRating": "5",
			"ratingCount": "40"
		},
		"founder": {
			"@type": "Person",
			"name": "Clement Daguet-Schott",
			"givenName": "Clement",
			"familyName": "Daguet-Schott",
			"jobTitle": "Guide & chercheur spécialisé Seconde Guerre mondiale",
			"description": "Guide indépendant spécialisé dans l'histoire de la Seconde Guerre mondiale à Paris. Après 6 mois de recherche intensive à travers plus de 20 ouvrages historiques et mémoires, Clément a créé des visites à pied immersives qui font revivre le Paris en guerre.",
			"knowsAbout": ["Histoire de la Seconde Guerre mondiale", "Paris pendant la Seconde Guerre mondiale", "Résistance française", "Libération de Paris 1944", "Occupation nazie de la France"],
			"knowsLanguage": ["en", "fr"],
			"image": "https://www.parishistorytours.com/photos/left_bank/Paris_WW2_guide.webp",
			"url": "https://www.parishistorytours.com/key-figures"
		},
		"hasOfferCatalog": {
			"@type": "OfferCatalog",
			"name": "Visites guidées Seconde Guerre mondiale à Paris",
			"itemListElement": [
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "TouristTrip",
						"name": "Visite Seconde Guerre mondiale Rive Gauche",
						"description": "Parcourez le Paris en guerre : Boulevard Saint-Michel, Palais du Luxembourg, Sorbonne & Notre-Dame. 2 heures, 4 arrêts sur la Chute, la Résistance & la Libération.",
						"touristType": ["Passionné d'histoire", "Voyageur culturel"],
						"duration": "PT2H",
						"url": "https://www.parishistorytours.com/fr/tours/left-bank"
					}
				},
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "TouristTrip",
						"name": "Visite Seconde Guerre mondiale Rive Droite",
						"description": "Découvrez le Paris de la Seconde Guerre mondiale : Pont Alexandre III, Place de la Concorde, Place Vendôme & le Ritz. Vol d'art, Hemingway & Libération. 2 heures, 4 arrêts.",
						"touristType": ["Passionné d'histoire", "Voyageur culturel"],
						"duration": "PT2H",
						"url": "https://www.parishistorytours.com/fr/tours/right-bank"
					}
				}
			]
		},
		"areaServed": {
			"@type": "City",
			"name": "Paris",
			"containedInPlace": {
				"@type": "Country",
				"name": "France"
			}
		},
		"sameAs": [
			"https://maps.app.goo.gl/AGYuzh8jHA9KXv9h8"
		]
	}} />
</BaseLayout>

<script>
	// Mobile menu functionality
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const hamburgerIcon = document.getElementById('hamburger-icon');
	const closeIcon = document.getElementById('close-icon');
	const mobileMenuItems = document.querySelectorAll('.mobile-menu-item');

	let isMenuOpen = false;

	function toggleMobileMenu() {
		isMenuOpen = !isMenuOpen;
		if (isMenuOpen) {
			mobileMenu?.classList.remove('hidden');
			setTimeout(() => {
				mobileMenu?.classList.remove('opacity-0', 'scale-95');
				mobileMenu?.classList.add('opacity-100', 'scale-100');
			}, 10);
			hamburgerIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		} else {
			mobileMenu?.classList.remove('opacity-100', 'scale-100');
			mobileMenu?.classList.add('opacity-0', 'scale-95');
			setTimeout(() => { mobileMenu?.classList.add('hidden'); }, 200);
			hamburgerIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}
	}

	mobileMenuBtn?.addEventListener('click', toggleMobileMenu);

	mobileMenuItems.forEach(item => {
		item.addEventListener('click', (e) => {
			e.preventDefault();
			const targetId = item.getAttribute('href')?.substring(1);
			const targetElement = document.getElementById(targetId || '');
			if (targetElement) {
				targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
				setTimeout(() => toggleMobileMenu(), 300);
			}
		});
	});

	document.addEventListener('click', (e) => {
		if (isMenuOpen && mobileMenu && !mobileMenu.contains(e.target as Node) && mobileMenuBtn && !mobileMenuBtn.contains(e.target as Node)) {
			toggleMobileMenu();
		}
	});
</script>
