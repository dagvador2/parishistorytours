---
import BaseLayout from "../layouts/BaseLayout.astro";
import Welcome from "../components/Welcome.astro";
import ToursAvailable from "../components/ToursAvailable.astro";
import Reviews from "../components/Reviews.astro";
import BookTour from "../components/BookTour.astro";
import "../styles/global.css";
import { useTranslations } from '../i18n/utils';

import JsonLd from "../components/JsonLd.astro";
import FAQ from "../components/FAQ.astro";
import LocationCarousel from "../components/ui/LocationCarousel.tsx";
import { AuroraBackground } from "../components/ui/aurora-background.tsx";
import Navbar from "../components/Navbar.astro";

const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.home.title')} description={t('meta.home.description')} ogImage="/photos/left_bank/Paris_WW2_guide.webp">
	<Navbar variant="homepage" />

	<!-- Hero section -->
	<section id="about" class="relative max-w-full text-lg leading-8 min-h-screen" style="font-family: 'Montserrat', Inter, system-ui, sans-serif;">
		{/* Aurora background — rendered as a fixed visual layer behind all content */}
		<div class="absolute inset-0 z-0">
			<AuroraBackground client:only="react" className="min-h-full" />
		</div>

		{/* Page content — rendered server-side as normal Astro HTML */}
		<div class="relative z-10 py-8 md:py-24 md:pt-20 px-2">
		{/* Titre principal et sous-titre */}
		<div class="max-w-4xl mx-auto flex flex-col items-center justify-center mb-0">
			<h1 class="text-4xl md:text-6xl font-bold text-center text-gray-800 m-0 p-0 mb-4">
				{t('home.title')}
			</h1>
			{/* Séparateur fin entre les titres */}
			<div class="w-16 h-px bg-gray-400 mb-4"></div>
			<h2 class="text-xl md:text-2xl font-medium text-center text-gray-600 m-0 p-0">
				{t('home.subtitle')}
			</h2>
		</div>

		{/* Hero gallery — Full-width location carousel */}
		<div class="max-w-5xl mx-auto mt-8 mb-4 px-4">
			<LocationCarousel
				client:only="react"
				cardsPerView={3}
				autoPlayMs={4000}
				height="30rem"
				cards={[
					{
						imgUrl: '/photos/left_bank/luxembourg_palace_paris.webp',
						title: t('home.gallery.pantheon.title'),
						subtitle: 'Left Bank Tour — Stop 2',
						description: t('home.gallery.pantheon.description') + ' The Palais du Luxembourg served as the Luftwaffe headquarters during the 4-year Nazi occupation of Paris.',
						tag: 'Left Bank Tour',
					},
					{
						imgUrl: '/photos/right_bank/place_vendome_paris_day.webp',
						title: t('home.gallery.placeVendome.title'),
						subtitle: 'Right Bank Tour — Stop 4',
						description: t('home.gallery.placeVendome.description') + ' This is where Ernest Hemingway famously arrived to "liberate" the Ritz bar on August 25, 1944.',
						tag: 'Right Bank Tour',
					},
					{
						imgUrl: '/photos/left_bank/notre-dame-de-paris.webp',
						title: 'Notre-Dame de Paris',
						subtitle: 'Left Bank Tour — Stop 4',
						description: "Witness to the Liberation of Paris in August 1944. General de Gaulle led a victory march here despite active sniper fire along the route.",
						tag: 'Left Bank Tour',
					},
					{
						imgUrl: '/photos/right_bank/bridge_alexander_third_paris.webp',
						title: 'Pont Alexandre III',
						subtitle: 'Right Bank Tour — Stop 1',
						description: "One of the bridges Hitler ordered to be destroyed before the Allied advance. It survived thanks to the German garrison's decision to disobey the demolition order.",
						tag: 'Right Bank Tour',
					},
					{
						imgUrl: '/photos/right_bank/place_concorde_paris.webp',
						title: 'Place de la Concorde',
						subtitle: 'Right Bank Tour — Stop 3',
						description: t('home.gallery.jeuDePaume.description') + " The site of the first French flag raised over a public building during the Liberation, replacing the swastika.",
						tag: 'Right Bank Tour',
					},
				]}
			/>
		</div>
		
		{/* Séparateur ligne */}
		<div class="flex justify-center mb-8">
			<div class="w-32 h-1 bg-gray-400 rounded-full"></div>
		</div>

		<Welcome />
		<ToursAvailable />
		<Reviews />

		<!-- Social Proof / Trust Signals -->
		<section class="py-12 bg-white/60 backdrop-blur-sm rounded-2xl mx-4 my-8">
			<div class="max-w-4xl mx-auto px-4 text-center">
				<h2 class="text-2xl font-bold text-gray-800 mb-6">{t('socialProof.title')}</h2>
				<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">4.9/5</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.googleRating')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">40+</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.reviews')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">25+</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.countries')}</div>
					</div>
					<div class="text-center">
						<div class="text-3xl font-bold text-gray-800">2024</div>
						<div class="text-sm text-gray-600 mt-1">{t('socialProof.founded')}</div>
					</div>
				</div>
				<p class="mt-8 text-gray-600 text-lg">{t('socialProof.description')}</p>
			</div>
		</section>

		<BookTour />
		<FAQ />
		</div>
	</section>

	<JsonLd data={{
		"@context": "https://schema.org",
		"@type": ["LocalBusiness", "TravelAgency"],
		"name": "Paris History Tours",
		"alternateName": "Paris History Tours - WWII Walking Tours",
		"description": t('meta.home.description'),
		"url": "https://www.parishistorytours.com",
		"telephone": "+33620622480",
		"email": "clemdaguetschott@gmail.com",
		"foundingDate": "2024",
		"slogan": "Discover Paris through the eyes of World War II",
		"knowsLanguage": ["en", "fr"],
		"currenciesAccepted": "EUR",
		"paymentAccepted": "Credit Card, Stripe",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Paris",
			"addressRegion": "Ile-de-France",
			"addressCountry": "FR"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 48.8566,
			"longitude": 2.3522
		},
		"image": "https://www.parishistorytours.com/photos/left_bank/Paris_WW2_guide.webp",
		"priceRange": "$$",
		"aggregateRating": {
			"@type": "AggregateRating",
			"ratingValue": "4.9",
			"bestRating": "5",
			"ratingCount": "40"
		},
		"founder": {
			"@type": "Person",
			"name": "Clement Daguet-Schott",
			"givenName": "Clement",
			"familyName": "Daguet-Schott",
			"jobTitle": "WWII History Guide & Researcher",
			"description": "Independent history guide specializing in World War II Paris. After 6 months of dedicated research across 20+ historical texts and memoirs, Clement created immersive walking tours that bring wartime Paris to life.",
			"knowsAbout": ["World War II history", "Paris during WWII", "French Resistance", "Liberation of Paris 1944", "Nazi occupation of France"],
			"knowsLanguage": ["en", "fr"],
			"image": "https://www.parishistorytours.com/photos/left_bank/Paris_WW2_guide.webp",
			"url": "https://www.parishistorytours.com/key-figures"
		},
		"hasOfferCatalog": {
			"@type": "OfferCatalog",
			"name": "WWII Walking Tours in Paris",
			"itemListElement": [
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "TouristTrip",
						"name": "Left Bank WWII Tour",
						"description": "Walk through wartime Paris: Boulevard Saint-Michel, Luxembourg Palace, Sorbonne & Notre-Dame. 2 hours, 4 stops covering the Fall, Resistance & Liberation.",
						"touristType": ["History enthusiast", "Cultural traveler"],
						"duration": "PT2H",
						"url": "https://www.parishistorytours.com/tours/left-bank"
					}
				},
				{
					"@type": "Offer",
					"itemOffered": {
						"@type": "TouristTrip",
						"name": "Right Bank WWII Tour",
						"description": "Discover WWII Paris: Pont Alexandre III, Place de la Concorde, Place Vendome & the Ritz. Art theft, Hemingway & Liberation stories. 2 hours, 4 stops.",
						"touristType": ["History enthusiast", "Cultural traveler"],
						"duration": "PT2H",
						"url": "https://www.parishistorytours.com/tours/right-bank"
					}
				}
			]
		},
		"areaServed": {
			"@type": "City",
			"name": "Paris",
			"containedInPlace": {
				"@type": "Country",
				"name": "France"
			}
		},
		"sameAs": [
			"https://maps.app.goo.gl/AGYuzh8jHA9KXv9h8"
		]
	}} />
</BaseLayout>

<script>
	import { initReviewCarousel } from '../scripts/review-carousel';
	import { initBookingUI } from '../scripts/booking-ui';
	import { initMobileMenu } from '../scripts/mobile-menu';

	initReviewCarousel(4);
	initBookingUI();
	initMobileMenu();
</script>

<script>
	import { initScrollBanner } from '../scripts/scroll-banner';

	initScrollBanner({
		bannerIds: ['book-banner-desktop', 'book-banner-mobile'],
		bookBtnIds: ['book-btn-desktop', 'book-btn-mobile'],
		showAfterPx: 200,
	});
</script>
