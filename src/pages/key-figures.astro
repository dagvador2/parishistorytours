---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';
import KeyFiguresStats from '../components/KeyFiguresStats.tsx';
import CountriesChart from '../components/CountriesChart.tsx';
import WorldMap from '../components/WorldMap.tsx';
import { useTranslations } from '../i18n/utils';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';
---

<BaseLayout title={t('meta.keyFigures.title')} description={t('meta.keyFigures.description')} ogImage="/photos/left_bank/Paris_WW2_guide.webp">
  <main class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100">
    <Breadcrumbs items={[
      { label: t('nav.home'), href: `${langPrefix}/` },
      { label: t('keyFigures.title') }
    ]} />
    <!-- Hero Section -->
    <section class="pt-12 pb-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            {t('keyFigures.title')}
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {t('keyFigures.subtitle')}
          </p>
        </div>
      </div>
    </section>

    <!-- About the Guide Section -->
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <img
              src="/photos/left_bank/Paris_WW2_guide.webp"
              alt="Clement Daguet-Schott - WWII History Guide in Paris"
              class="rounded-lg shadow-xl w-full h-96 object-cover"
              loading="eager"
            />
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('keyFigures.guide.title')}</h2>
            <p class="text-gray-700 mb-4 leading-relaxed">{t('keyFigures.guide.bio1')}</p>
            <p class="text-gray-700 mb-4 leading-relaxed">{t('keyFigures.guide.bio2')}</p>
            <p class="text-gray-700 leading-relaxed">{t('keyFigures.guide.bio3')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Building the Tours Section -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('keyFigures.building.title')}</h2>
          <p class="text-lg text-gray-600">
            {t('keyFigures.building.subtitle')}
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="space-y-8">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{t('keyFigures.building.books.title')}</h3>
                <p class="text-gray-600">
                  {t('keyFigures.building.books.description')}
                </p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0 w-16 h-16 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{t('keyFigures.building.months.title')}</h3>
                <p class="text-gray-600">
                  {t('keyFigures.building.months.description')}
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative">
            <img 
              src="/photos/book_ww2_guide_paris.webp" 
              alt="Historical research books"
              class="rounded-lg shadow-xl w-full h-96 object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-lg"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Delivering the Tour Section -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">{t('keyFigures.delivering.title')}</h2>
          <p class="text-lg text-gray-600">
            {t('keyFigures.delivering.subtitle')}
          </p>
        </div>

        <!-- Stats Component -->
        <KeyFiguresStats client:load />

        <!-- AI-readable statistics (React charts are not crawlable) -->
        <div class="sr-only">
          <p>{lang === 'fr'
            ? 'Chiffres clés de Paris History Tours : plus de 300 participants venus de plus de 25 pays à travers plus de 60 visites guidées, couvrant plus de 150 kilomètres de parcours pédestres dans le Paris historique. Les visiteurs viennent des États-Unis, du Royaume-Uni, d\'Allemagne, de France, du Canada, d\'Australie, d\'Espagne et de nombreux autres pays. Fondé en 2024, Paris History Tours maintient une note de 4.9 sur 5 étoiles avec plus de 40 avis Google.'
            : 'Paris History Tours key statistics: over 300 participants from 25+ countries across 60+ guided tours, covering more than 150 kilometers of walking tours through historic Paris. Visitors come from the United States, United Kingdom, Germany, France, Canada, Australia, Spain, and many more countries. Founded in 2024, Paris History Tours has maintained a 4.9 out of 5 star rating across 40+ Google reviews.'
          }</p>
        </div>

        <!-- Countries Chart -->
        <div class="mt-16">
          <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">
            {t('keyFigures.delivering.topCountries')}
          </h3>
          <div class="bg-white rounded-lg shadow-lg p-8">
            <CountriesChart client:load />
          </div>
        </div>

        <!-- World Map - Garder seulement celle-ci -->
        <div class="mt-16">
          <WorldMap client:load />
        </div>
      </div>
    </section>
  </main>

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Clement Daguet-Schott",
    "givenName": "Clement",
    "familyName": "Daguet-Schott",
    "jobTitle": "WWII History Guide & Researcher",
    "description": "Independent history guide in Paris specializing in World War II walking tours. Conducted extensive research across 20+ historical texts over 6 months to create immersive experiences visiting landmarks from the Fall, Resistance, and Liberation of Paris.",
    "worksFor": {
      "@type": "LocalBusiness",
      "name": "Paris History Tours",
      "url": "https://www.parishistorytours.com"
    },
    "knowsAbout": [
      "World War II in Paris",
      "French Resistance",
      "Liberation of Paris 1944",
      "Fall of France 1940",
      "Nazi occupation of Paris",
      "Rose Valland and Nazi art theft",
      "Ernest Hemingway and the Liberation",
      "Agnes Humbert and Musee de l'Homme network",
      "Charles de Gaulle"
    ],
    "knowsLanguage": ["en", "fr"],
    "image": "https://www.parishistorytours.com/photos/left_bank/Paris_WW2_guide.webp",
    "url": "https://www.parishistorytours.com/key-figures"
  }} />
</BaseLayout>
