---
import { Picture } from 'astro:assets';
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsonLd from "../../components/JsonLd.astro";
import { useTranslations } from '../../i18n/utils';
import { tours } from '../../data/tours';

import TopBar from "../../components/quiet/TopBar.astro";
import Nav from "../../components/quiet/Nav.astro";
import MobileBookingBar from "../../components/quiet/MobileBookingBar.astro";
import TourHero from "../../components/quiet/TourHero.astro";
import DidYouKnowStrip from "../../components/quiet/DidYouKnowStrip.astro";
import ThemesGrid from "../../components/quiet/ThemesGrid.astro";
import StopsSection from "../../components/quiet/StopsSection.astro";
import RouteDetail from "../../components/quiet/RouteDetail.astro";
import GalleryGrid from "../../components/quiet/GalleryGrid.astro";
import BookingCard from "../../components/quiet/BookingCard.astro";
import FAQ from "../../components/quiet/FAQ.astro";

import pantheon from "../../images/pantheon_de_Paris.webp";
import vendome from "../../images/place_vendome_paris.webp";
import ileDeLaCite from "../../images/ile_de_la_cite_paris.webp";

const heroImages: Record<string, ImageMetadata> = {
  'left-bank': pantheon,
  'right-bank': vendome,
  'general-history': ileDeLaCite,
};

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { tour: 'left-bank' } },
    { params: { tour: 'right-bank' } },
    { params: { tour: 'general-history' } },
  ];
}

const { tour: tourSlug } = Astro.params;
const tourConfig = tours[tourSlug];

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';
const tp = tourConfig.translationPrefix;
const heroImage = heroImages[tourConfig.heroImageKey];
const isGeneral = tourSlug === 'general-history';

// Hero kicker per tour (short editorial label above the title)
const kickerKey = tourSlug === 'left-bank'  ? 'quiet.tour.heroKickerLeftBank'
                : tourSlug === 'right-bank' ? 'quiet.tour.heroKickerRightBank'
                :                              'quiet.tour.heroKickerGeneral';
const heroKicker = t(kickerKey);
const heroTitle = t(`tours.${tp}.title`);
const heroSubtitle = t(`tours.${tp}.description`);

// JSON-LD helpers (unchanged from legacy template)
const jsonLdDuration = isGeneral ? 'PT1H30M' : 'PT2H';
const jsonLdTourName = isGeneral
  ? heroTitle + " - Paris Walking Tour"
  : heroTitle + " - Paris WWII Walking Tour";
const jsonLdTouristType = isGeneral
  ? ["History enthusiast", "Cultural traveler", "First-time visitor"]
  : ["History enthusiast", "Cultural traveler"];
const jsonLdGuideJobTitle = isGeneral
  ? "History Guide & Researcher"
  : "WWII History Guide & Researcher";
---

<BaseLayout
  title={t(`meta.${tp}.title`)}
  description={t(`meta.${tp}.description`)}
  ogImage={tourConfig.ogImage}
  theme="quiet"
>
  <TopBar />
  <Nav context="tour" />

  <main>
    <TourHero
      image={heroImage}
      alt={tourConfig.heroAlt}
      kicker={heroKicker}
      title={heroTitle}
      subtitle={heroSubtitle}
    />

    <DidYouKnowStrip tp={tp} />

    <ThemesGrid themeKeys={tourConfig.themeKeys} topics={tourConfig.topics} isGeneral={isGeneral} />

    <StopsSection tour={tourConfig} isGeneral={isGeneral} />

    <RouteDetail tour={tourConfig} isGeneral={isGeneral} />

    <GalleryGrid images={tourConfig.galleryDesktop} />

    <BookingCard tour={tourConfig} isGeneral={isGeneral} />

    <!-- Other tours — hairline-bordered cross-promo with images -->
    <section class="qother">
      <div class="qother__inner">
        <header class="qother__header">
          <p class="qother__kicker">{t('quiet.tour.other.kicker')}</p>
          <h2 class="qother__title">{t('quiet.tour.other.title')}</h2>
        </header>
        <div class={`qother__grid qother__grid--${tourConfig.crossLinks.length}`}>
          {tourConfig.crossLinks.map((link) => {
            const img = heroImages[link.slug];
            return (
              <a href={`${langPrefix}/tours/${link.slug}`} class="qother__card">
                {img && (
                  <div class="qother__img">
                    <Picture
                      src={img}
                      alt={t(`booking.${link.bookingKey}`)}
                      widths={[480, 720, 960]}
                      sizes="(max-width: 760px) 100vw, 40vw"
                      formats={["avif", "webp"]}
                      quality={80}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="qother__body">
                  <p>{lang === 'fr' ? link.descriptionFr : link.descriptionEn}</p>
                  <span class="qother__link">{t(`booking.${link.bookingKey}`)} <span aria-hidden="true">→</span></span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <FAQ />
  </main>

  <MobileBookingBar href="#book" />

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": jsonLdTourName,
    "description": t(`meta.${tp}.description`),
    "touristType": jsonLdTouristType,
    "itinerary": {
      "@type": "ItemList",
      "numberOfItems": tourConfig.stopCount,
      "itemListElement": Array.from({ length: tourConfig.stopCount }, (_, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": t(`tours.${tp}.stops.stop${i + 1}.title`)
      }))
    },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "url": `https://www.parishistorytours.com/tours/${tourConfig.slug}`
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": "Paris History Tours",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "40"
      }
    },
    "guide": {
      "@type": "Person",
      "name": "Clement Daguet-Schott",
      "jobTitle": jsonLdGuideJobTitle
    },
    "location": {
      "@type": "Place",
      "name": tourConfig.locationName,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Paris",
        "addressCountry": "FR"
      }
    },
    "audience": {
      "@type": "PeopleAudience",
      "suggestedMinAge": 14,
      "audienceType": "History enthusiasts, tourists, students, educators"
    },
    "maximumAttendeeCapacity": 10,
    "isAccessibleForFree": false,
    "duration": jsonLdDuration,
    "inLanguage": ["en", "fr"]
  }} />
</BaseLayout>

<script>
  import { initQuietNav } from '../../scripts/quiet-nav';
  initQuietNav();
</script>

<style>
  .qother {
    background: var(--paper-2);
    padding: 72px 32px;
    border-top: 1px solid var(--border);
  }
  .qother__inner { max-width: 1100px; margin: 0 auto; }
  .qother__header { max-width: 640px; margin: 0 0 40px; }
  .qother__kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rouge);
    margin: 0 0 16px;
  }
  .qother__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(28px, 3.2vw, 40px);
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
    line-height: 1.15;
  }
  .qother__grid {
    display: grid;
    gap: 24px;
  }
  .qother__grid--2 { grid-template-columns: 1fr 1fr; }
  .qother__grid--1 { grid-template-columns: 1fr; max-width: 560px; }

  .qother__card {
    display: flex;
    flex-direction: column;
    background: var(--paper-3);
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 160ms ease;
    overflow: hidden;
  }
  .qother__card:hover { border-color: var(--ink); }
  .qother__img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-2);
  }
  .qother__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .qother__card:hover .qother__img img { transform: scale(1.03); }
  .qother__body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    padding: 24px 28px 26px;
    flex: 1;
  }
  .qother__card p {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0;
  }
  .qother__link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    display: inline-flex;
    gap: 6px;
    align-items: center;
  }
  .qother__card:hover .qother__link span { display: inline-block; transform: translateX(4px); transition: transform 160ms ease; }

  @media (max-width: 760px) {
    .qother { padding: 48px 20px; }
    .qother__grid--2 { grid-template-columns: 1fr; }
  }
</style>
