---
import { Picture } from "astro:assets";

import BaseLayout from "../../layouts/BaseLayout.astro";
import BookTour from "../../components/BookTour.astro";
import TourMap from "../../components/TourMap.tsx";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import pantheon from "../../images/pantheon_de_Paris.webp";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Create language-aware navigation links
const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';
---

<BaseLayout title="Left Bank Tour - Paris History Tours" description="Left Bank WWII walking tour in Paris: Fall of Paris, Resistance, and Liberation.">
  <!-- Language switcher -->
  <div class="fixed top-4 left-4 z-50">
    <LanguageSwitcher />
  </div>

  <!-- Bannière Book Tour (cachée par défaut, apparaît au scroll) -->
  <nav id="book-banner" class="fixed top-0 left-0 w-full bg-gray-600 border-b border-gray-700 z-[9998] shadow-lg transform -translate-y-full transition-transform duration-300">
    <div class="flex items-center justify-center py-3 px-4">
      <button id="book-btn-tour-page" class="bg-white text-gray-600 font-bold hover:bg-blue-50 transition-colors duration-200 px-6 py-2 rounded-lg shadow-md">{t('nav.bookTour')}</button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 to-gray-700">
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0">
      <Picture
      src={pantheon}
      alt="Panthéon de Paris – Memorial to Resistance heroes"
      widths={[640,768,1024,1440]}
      sizes="100vw"
      formats={["avif","webp"]}
      loading="lazy"
      decoding="async"
      quality={75} 
        class="w-full h-full object-cover"
      />
    </div>
    <div class="relative z-10 text-center text-white max-w-4xl mx-auto px-4">
      <h1 class="text-5xl md:text-7xl font-bold mb-6">{t('tours.leftBank.title')}</h1>
      <p class="text-xl md:text-2xl mb-8 opacity-90">
        {t('tours.leftBank.description')}
      </p>
      <div class="flex flex-col md:flex-row md:flex-wrap md:justify-center gap-4 md:gap-8 text-lg md:text-xl">
        <div class="flex items-center justify-center gap-3">
          <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
          </svg>
          <span class="font-medium">{t('common.duration')}</span>
        </div>
        <div class="flex items-center justify-center gap-3">
          <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          <span class="font-medium">{t('common.distance')}</span>
        </div>
        <div class="flex items-center justify-center gap-3">
          <svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-medium">{t('common.stops')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-8 text-gray-800">
        {t('tours.leftBank.introduction')}
      </h2>
      <div class="text-center">
        <blockquote class="text-2xl md:text-3xl font-medium text-gray-700 italic mb-6">
          "{t('tours.leftBank.quote')}"
        </blockquote>
        <cite class="text-lg text-gray-600">
          — {t('tours.leftBank.quoteAuthor')}
        </cite>
        <p class="mt-6 text-gray-700">
          {t('tours.leftBank.summary')}
        </p>
      </div>
    </div>
  </section>

  <!-- Three Topics Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <h3 class="text-2xl md:text-3xl font-bold text-center mb-8 text-gray-800">
        {t('tours.themes.title')}
      </h3>
      
      <!-- Desktop Version -->
      <div class="hidden md:grid md:grid-cols-3 gap-8">
        <!-- The Fall -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <div class="h-48 relative">
            <img
              src="/photos/fall_of_paris_ww2_1940.webp"
              alt="Fall of Paris 1940"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="640"
              height="384"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
              <h3 class="text-2xl font-bold text-white">{t('tours.themes.fall.title')}</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-700 leading-relaxed">
              {t('tours.themes.fall.description')}
            </p>
          </div>
        </div>

        <!-- The Resistance -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <div class="h-48 relative">
            <img
              src="/photos/resistance_ww2_paris.webp"
              alt="Resistance in Paris"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="640"
              height="384"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
              <h3 class="text-2xl font-bold text-white">{t('tours.themes.resistance.title')}</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-700 leading-relaxed">
              {t('tours.themes.resistance.description')}
            </p>
          </div>
        </div>

        <!-- Liberation -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <div class="h-48 relative">
            <img
              src="/photos/paris_ww2_liberation_1944_de_gaulle.webp"
              alt="Liberation of Paris 1944"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="640"
              height="384"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
              <h3 class="text-2xl font-bold text-white">{t('tours.themes.liberation.title')}</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-700 leading-relaxed">
              {t('tours.themes.liberation.description')}
            </p>
          </div>
        </div>
      </div>

      <!-- Mobile Version with Swipe Carousel -->
      <div class="md:hidden">
        <div class="relative max-w-sm mx-auto">
          <div class="overflow-hidden rounded-xl">
            <div class="flex transition-transform duration-300 ease-in-out" id="topics-carousel">
              <!-- The Fall -->
              <div class="min-w-full">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                  <div class="h-48 relative">
                    <img
                      src="/photos/fall_of_paris_ww2_1940.webp"
                      alt="Fall of Paris 1940"
                      loading="lazy"
                      decoding="async"
                      width="640"
                      height="384"
                      class="w-full h-full object-cover"
                    />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                      <h3 class="text-2xl font-bold text-white">{t('tours.themes.fall.title')}</h3>
                    </div>
                  </div>
                  <div class="p-6">
                    <p class="text-gray-700 leading-relaxed">
                      {t('tours.themes.fall.description')}
                    </p>
                  </div>
                </div>
              </div>
              
              <!-- The Resistance -->
              <div class="min-w-full">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                  <div class="h-48 relative">
                    <img
                      src="/photos/resistance_ww2_paris.webp"
                      alt="Resistance in Paris"
                      loading="lazy"
                      decoding="async"
                      width="640"
                      height="384"
                      class="w-full h-full object-cover"
                    />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                      <h3 class="text-2xl font-bold text-white">{t('tours.themes.resistance.title')}</h3>
                    </div>
                  </div>
                  <div class="p-6">
                    <p class="text-gray-700 leading-relaxed">
                      {t('tours.themes.resistance.description')}
                    </p>
                  </div>
                </div>
              </div>
              
              <!-- Liberation -->
              <div class="min-w-full">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                  <div class="h-48 relative">
                    <img
                      src="/photos/paris_ww2_liberation_1944_de_gaulle.webp"
                      alt="Liberation of Paris 1944"
                      loading="lazy"
                      decoding="async"
                      width="640"
                      height="384"
                      class="w-full h-full object-cover"
                    />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                      <h3 class="text-2xl font-bold text-white">{t('tours.themes.liberation.title')}</h3>
                    </div>
                  </div>
                  <div class="p-6">
                    <p class="text-gray-700 leading-relaxed">
                      {t('tours.themes.liberation.description')}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Indicators -->
          <div class="flex justify-center mt-4 space-x-2" id="topics-indicators">
            <button class="w-3 h-3 rounded-full bg-gray-800 transition-all duration-200" data-index="0"></button>
            <button class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-200" data-index="1"></button>
            <button class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-200" data-index="2"></button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tour Stops Section -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800">
        Our 4 Historic Stops
      </h2>
      
      <!-- Desktop Version - Grid normale -->
      <div class="hidden md:block">
        <!-- Stop 1: Introduction & History Catch-up -->
        <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-gray-600 text-white rounded-full flex items-center justify-center text-xl font-bold">1</div>
              <h3 class="text-2xl font-bold text-gray-800">Boulevard Saint-Michel - Introduction</h3>
            </div>
            <p class="text-lg text-gray-700 leading-relaxed">
              Begin your journey at this iconic boulevard with a presentation of the tour and a quick history quiz to put everyone on the same page! Discover how Paris looked on the eve of the German invasion and see the first signs of the war that still remain in the city to this day.
            </p>
          </div>
          <div class="relative">
            <img
              src="/photos/left_bank/Paris_WW2_bullet_holes_2.webp"
              alt="Boulevard Saint-Michel area"
              loading="lazy"
              decoding="async"
              width="800"
              height="426"
              class="rounded-lg shadow-lg w-full h-64 object-cover"
            />
          </div>
        </div>

        <!-- Stop 2: The Fall of Paris -->
        <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
          <div class="md:order-2">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-gray-600 text-white rounded-full flex items-center justify-center text-xl font-bold">2</div>
              <h3 class="text-2xl font-bold text-gray-800">Palais du Luxembourg - The Fall</h3>
            </div>
            <p class="text-lg text-gray-700 leading-relaxed">
              Walk through the gardens of this magnificent palace and discover how Paris fell to the German army in only 35 days of combat. Learn about the crucial 35 days that changed the city forever and how the Nazis transformed this symbol of French culture into their Air Force command center.
            </p>
          </div>
          <div class="md:order-1 relative">
            <img
              src="/photos/left_bank/luxembourg_palace_paris.webp"
              alt="Palais du Luxembourg during occupation"
              loading="lazy"
              decoding="async"
              width="800"
              height="426"
              class="rounded-lg shadow-lg w-full h-64 object-cover"
            />
          </div>
        </div>

        <!-- Stop 3: The Resistance -->
        <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-gray-600 text-white rounded-full flex items-center justify-center text-xl font-bold">3</div>
              <h3 class="text-2xl font-bold text-gray-800">La Sorbonne - The Resistance</h3>
            </div>
            <p class="text-lg text-gray-700 leading-relaxed">
              Near this historic university, discover the story of Agnès Humbert, a brave French Resistance fighter who was part of the first organized resistance network in Paris, called Musée de l'Homme. Learn about one of the earliest resistance movements in the city and how these courageous individuals risked everything to fight against the occupation.
            </p>
          </div>
          <div class="relative">
            <img
              src="/photos/left_bank/sorbonne_paris.webp"
              alt="Resistance memorial at Sorbonne"
              loading="lazy"
              decoding="async"
              width="800"
              height="426"
              class="rounded-lg shadow-lg w-full h-64 object-cover"
              style="object-position: center top;"
            />
          </div>
        </div>

        <!-- Stop 4: Liberation -->
        <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
          <div class="md:order-2">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-gray-600 text-white rounded-full flex items-center justify-center text-xl font-bold">4</div>
              <h3 class="text-2xl font-bold text-gray-800">Notre-Dame de Paris - Liberation</h3>
            </div>
            <p class="text-lg text-gray-700 leading-relaxed">
              Conclude our tour at this iconic cathedral, witness to the liberation of Paris in August 1944. Learn more about the fights that took place in Paris 81 years ago. Stand where General de Gaulle proclaimed the freedom of the capital and discover how closely Paris came to being greatly damaged.
            </p>
          </div>
          <div class="md:order-1 relative">
            <img
              src="/photos/left_bank/notre-dame-de-paris.webp"
              alt="Liberation barricades near Notre-Dame"
              loading="lazy"
              decoding="async"
              width="800"
              height="426"
              class="rounded-lg shadow-lg w-full h-64 object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Mobile Version - Full-width Carousel -->
      <div class="md:hidden relative">
        <div class="overflow-hidden rounded-xl">
          <div class="flex transition-transform duration-300 ease-in-out" id="stops-carousel">
            <!-- Stop 1 -->
            <div class="min-w-full">
              <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <img
                  src="/photos/left_bank/Paris_WW2_bullet_holes_2.webp"
                  alt="Boulevard Saint-Michel area"
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="384"
                  class="w-full h-56 object-cover"
                  style="object-position: center top;"
                />
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 bg-gray-600 text-white rounded-full flex items-center justify-center text-sm font-bold">1</div>
                    <h3 class="text-xl font-bold text-gray-800">Boulevard Saint-Michel - Introduction</h3>
                  </div>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    Begin your journey at this iconic boulevard with a presentation of the tour and a quick history quiz to put everyone on the same page! Discover how Paris looked on the eve of the German invasion and see the first signs of the war that still remain in the city to this day.
                  </p>
                </div>
              </div>
            </div>
            <!-- Stop 2 -->
            <div class="min-w-full">
              <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <img
                  src="/photos/left_bank/luxembourg_palace_paris.webp"
                  alt="Palais du Luxembourg during occupation"
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="384"
                  class="w-full h-56 object-cover"
                  style="object-position: center top;"
                />
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 bg-gray-600 text-white rounded-full flex items-center justify-center text-sm font-bold">2</div>
                    <h3 class="text-xl font-bold text-gray-800">Palais du Luxembourg - The Fall</h3>
                  </div>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    Walk through the gardens of this magnificent palace and discover how Paris fell to the German army in only 35 days of combat. Learn about the crucial 35 days that changed the city forever and how the Nazis transformed this symbol of French culture into their Air Force command center.
                  </p>
                </div>
              </div>
            </div>
            <!-- Stop 3 (aligned with bureau) -->
            <div class="min-w-full">
              <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <img
                  src="/photos/left_bank/sorbonne_paris.webp"
                  alt="Resistance memorial at Sorbonne"
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="384"
                  class="w-full h-56 object-cover"
                  style="object-position: center top;"
                />
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 bg-gray-600 text-white rounded-full flex items-center justify-center text-sm font-bold">3</div>
                    <h3 class="text-xl font-bold text-gray-800">La Sorbonne - The Resistance</h3>
                  </div>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    Near this historic university, discover the story of Agnès Humbert, a brave French Resistance fighter who was part of the first organized resistance network in Paris, called Musée de l'Homme. Learn about one of the earliest resistance movements in the city and how these courageous individuals risked everything to fight against the occupation.
                  </p>
                </div>
              </div>
            </div>
            <!-- Stop 4 (aligned with bureau) -->
            <div class="min-w-full">
              <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <img
                  src="/photos/left_bank/notre-dame-de-paris.webp"
                  alt="Liberation barricades near Notre-Dame"
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="384"
                  class="w-full h-56 object-cover"
                  style="object-position: center top;"
                />
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 bg-gray-600 text-white rounded-full flex items-center justify-center text-sm font-bold">4</div>
                    <h3 class="text-xl font-bold text-gray-800">Notre-Dame de Paris - Liberation</h3>
                  </div>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    Conclude our tour at this iconic cathedral, witness to the liberation of Paris in August 1944. Learn more about the fights that took place in Paris 81 years ago. Stand where General de Gaulle proclaimed the freedom of the capital and discover how closely Paris came to being greatly damaged.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="flex justify-center mt-6 space-x-2" id="stops-indicators">
          <button class="w-3 h-3 rounded-full bg-gray-800 transition-all duration-200" data-index="0"></button>
          <button class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-200" data-index="1"></button>
          <button class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-200" data-index="2"></button>
          <button class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-200" data-index="3"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- Tour Route Section -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-8 text-gray-800">
        Our Route Through Paris
      </h2>
      <TourMap tour="left-bank" client:visible />
    </div>
  </section>

  <!-- Gallery Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800">
        Experience the History
      </h2>
      
      <!-- Desktop Version - Grid normale -->
      <div class="hidden md:grid md:grid-cols-4 gap-4">
        <img
          src="/photos/left_bank/Paris_WW2_bullet_holes_2.webp"
          alt="Bullet holes from the war"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_german_attack.webp"
          alt="German attack on Paris"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_ww2_group_photo.webp"
          alt="Tour group photo"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_guide.webp"
          alt="Your guide Clément"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_last_stop.webp"
          alt="Final stop of the tour"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_resistance.webp"
          alt="Resistance memorial"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_tour_guided_group_photo_2.webp"
          alt="Another group photo"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
        <img
          src="/photos/left_bank/Paris_WW2_tour_guided_group_photo_3.webp"
          alt="Group enjoying the tour"
          loading="lazy"
          decoding="async"
          width="400"
          height="300"
          class="rounded-lg shadow-md w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
        />
      </div>

      <!-- Mobile Version - Scroll Snap (REMPLACE ancien carrousel JS) -->
      <div class="md:hidden">
        <div class="-mx-4 px-4">
          <div
            class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 scrollbar-hide overscroll-x-contain"
            style="scroll-behavior:smooth;"
          >
            <!-- Chaque image devient une carte (utiliser mêmes images + alts que la version bureau) -->
            {
              [
                { src: "/photos/left_bank/Paris_WW2_bullet_holes_2.webp", alt: "Bullet holes from the war" },
