<style>
  /* Masquer scrollbar (mobile / webkit) */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  /* Meilleure inertie iOS */
  .scrollbar-hide { -webkit-overflow-scrolling: touch; }
</style>

<script>
  // Mobile topics carousel functionality
  let currentTopicIndex = 0;
  const totalTopics = 3;
  const topicsCarousel = document.getElementById('topics-carousel');
  const topicsIndicators = document.querySelectorAll('#topics-indicators button');

  function updateTopicsCarousel() {
    const offset = -currentTopicIndex * 100;
    if (topicsCarousel) topicsCarousel.style.transform = `translateX(${offset}%)`;
    topicsIndicators.forEach((indicator, index) => {
      indicator.classList.toggle('bg-gray-800', index === currentTopicIndex);
      indicator.classList.toggle('bg-gray-300', index !== currentTopicIndex);
    });
  }

  topicsIndicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => { currentTopicIndex = index; updateTopicsCarousel(); });
  });

  // Touch/Swipe support for topics
  let topicsTouchStartX = 0;
  let topicsTouchEndX = 0;
  const minSwipeDistance = 50;
  if (topicsCarousel) {
    topicsCarousel.addEventListener('touchstart', e => { topicsTouchStartX = e.changedTouches[0].screenX; }, { passive: true });
    topicsCarousel.addEventListener('touchend', e => { topicsTouchEndX = e.changedTouches[0].screenX; handleTopicsSwipe(); }, { passive: true });
  }
  function handleTopicsSwipe() {
    const deltaX = topicsTouchEndX - topicsTouchStartX;
    if (Math.abs(deltaX) > minSwipeDistance) {
      currentTopicIndex = deltaX > 0
        ? (currentTopicIndex - 1 + totalTopics) % totalTopics
        : (currentTopicIndex + 1) % totalTopics;
      updateTopicsCarousel();
    }
  }

  // Auto-play désactivé (inutile / gênant UX)
  // setInterval(nextTopic, 10000);
</script>

<script>
  // Stops carousel functionality (mobile)
  let currentStopIndex = 0;
  const totalStops = 4;
  const stopsCarousel = document.getElementById('stops-carousel');
  const stopsIndicators = document.querySelectorAll('#stops-indicators button');

  function updateStopsCarousel() {
    const offset = -currentStopIndex * 100;
    if (stopsCarousel) stopsCarousel.style.transform = `translateX(${offset}%)`;
    stopsIndicators.forEach((indicator, index) => {
      indicator.classList.toggle('bg-gray-800', index === currentStopIndex);
      indicator.classList.toggle('bg-gray-300', index !== currentStopIndex);
    });
  }

  // Swipe (conservation du contrôle gestuel)
  let stopsTouchStartX = 0;
  let stopsTouchEndX = 0;
  const minSwipeDistanceStops = 50;
  if (stopsCarousel) {
    stopsCarousel.addEventListener('touchstart', e => { stopsTouchStartX = e.changedTouches[0].screenX; }, { passive: true });
    stopsCarousel.addEventListener('touchend', e => { stopsTouchEndX = e.changedTouches[0].screenX; handleStopsSwipe(); }, { passive: true });
  }
  function handleStopsSwipe() {
    const deltaX = stopsTouchEndX - stopsTouchStartX;
    if (Math.abs(deltaX) > minSwipeDistanceStops) {
      currentStopIndex = deltaX > 0
        ? (currentStopIndex - 1 + totalStops) % totalStops
        : (currentStopIndex + 1) % totalStops;
      updateStopsCarousel();
    }
  }

  // Indicateurs cliquables
  stopsIndicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => { currentStopIndex = index; updateStopsCarousel(); });
  });

  // Auto-play désactivé (meilleure UX)
  // setInterval(nextStop, 15000);
</script>

<script>
  // Bannière Book Tour au scroll
  let lastScrollY = 0;
  const bookBanner = document.getElementById('book-banner');
  const bookBtnTourPage = document.getElementById('book-btn-tour-page');

  function handleScroll() {
    const currentScrollY = window.scrollY;
    const bookingSection = document.querySelector('div[id*="book-tour"]') || document.querySelector('[id="book-tour"]');
    let hideThreshold = window.innerHeight; // Valeur par défaut
    
    if (bookingSection) {
      const rect = bookingSection.getBoundingClientRect();
      const sectionTop = currentScrollY + rect.top;
      hideThreshold = sectionTop - 100; // Cache la bannière 100px avant la section
    }
    
    if (currentScrollY > 200 && currentScrollY < hideThreshold) {
      // Apparaît après 200px et disparaît avant la section booking
      bookBanner?.classList.remove('-translate-y-full');
    } else {
      bookBanner?.classList.add('-translate-y-full');
    }
    
    lastScrollY = currentScrollY;
  }

  // Scroll vers la section booking
  function scrollToBooking() {
    const bookingSection = document.querySelector('div[id*="book-tour"]') || document.querySelector('[id="book-tour"]');
    if (bookingSection) {
      bookingSection.scrollIntoView({ 
        behavior: 'smooth',
        block: 'start'
      });
    }
  }

  // Event listeners
  window.addEventListener('scroll', handleScroll, { passive: true });
  
  if (bookBtnTourPage) {
    bookBtnTourPage.addEventListener('click', scrollToBooking);
  }
</script>
