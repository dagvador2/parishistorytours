---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

import TopBar from '../../components/quiet/TopBar.astro';
import Nav from '../../components/quiet/Nav.astro';
import MobileBookingBar from '../../components/quiet/MobileBookingBar.astro';
import ArticleHero from '../../components/quiet/ArticleHero.astro';
import ArticleCTA from '../../components/quiet/ArticleCTA.astro';
import ArticleAuthor from '../../components/quiet/ArticleAuthor.astro';
import ArticleRelated from '../../components/quiet/ArticleRelated.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';

// Related posts: same language, exclude current, most recent first, max 3
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.data.lang === post.data.lang && p.id !== post.id)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const canonicalUrl = `https://www.parishistorytours.com${langPrefix}/blog/${post.id}`;
const imageUrl = post.data.image ? `https://www.parishistorytours.com${post.data.image}` : undefined;
---

<BaseLayout
  title={`${post.data.title} | Paris History Tours`}
  description={post.data.description}
  ogImage={post.data.image}
  theme="quiet"
>
  <TopBar />
  <Nav context="tour" />

  <main class="qarticle">
    <ArticleHero
      title={post.data.title}
      description={post.data.description}
      author={post.data.author}
      publishDate={post.data.publishDate}
      tags={post.data.tags}
      image={post.data.image}
      imageAlt={post.data.imageAlt}
      blogHref={`${langPrefix}/blog`}
    />

    <article class="qarticle__body">
      <div class="article-content">
        <Content />
      </div>
    </article>

    <ArticleCTA
      bookHref={`${langPrefix}/#book`}
      toursHref={`${langPrefix}/#tours`}
    />

    <ArticleAuthor authorLink={`${langPrefix}/key-figures`} />

    <ArticleRelated posts={relatedPosts} langPrefix={langPrefix} />
  </main>

  <MobileBookingBar href={`${langPrefix}/#book`} />

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "author": {
      "@type": "Person",
      "name": "Clement Daguet-Schott",
      "url": "https://www.parishistorytours.com/key-figures"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Paris History Tours",
      "url": "https://www.parishistorytours.com"
    },
    "datePublished": post.data.publishDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.publishDate).toISOString(),
    "mainEntityOfPage": canonicalUrl,
    ...(imageUrl ? { "image": imageUrl } : {}),
    "inLanguage": post.data.lang
  }} />
</BaseLayout>

<script>
  import { initQuietNav } from '../../scripts/quiet-nav';
  initQuietNav();
</script>

<style>
  .qarticle { background: var(--paper); }
  .qarticle__body {
    max-width: 720px;
    margin: 0 auto;
    padding: 72px 32px;
  }

  .article-content {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.8;
    color: var(--ink);
  }

  .article-content :global(p) {
    margin: 0 0 1.6em;
  }

  .article-content :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 32px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-top: 2.4em;
    margin-bottom: 0.6em;
    line-height: 1.15;
  }

  .article-content :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin-top: 2em;
    margin-bottom: 0.6em;
    line-height: 1.2;
  }

  .article-content :global(h4) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0 0 1.6em;
    padding-left: 1.5em;
  }
  .article-content :global(ul) { list-style-type: disc; }
  .article-content :global(ol) { list-style-type: decimal; }
  .article-content :global(li) {
    margin-bottom: 0.5em;
    padding-left: 0.25em;
  }
  .article-content :global(li::marker) { color: var(--ink-2); }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }
  .article-content :global(em) {
    font-style: italic;
  }

  .article-content :global(a) {
    color: var(--rouge);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 120ms ease;
  }
  .article-content :global(a:hover) {
    color: var(--rouge-dark);
  }

  .article-content :global(blockquote) {
    border-left: 2px solid var(--ink);
    padding: 4px 0 4px 28px;
    margin: 2.4em 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.5;
    color: var(--ink);
  }
  .article-content :global(blockquote p) {
    margin: 0 0 0.5em;
  }
  .article-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3em auto;
    width: 48px;
  }

  .article-content :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 2em 0;
    border: 1px solid var(--border);
  }

  .article-content :global(code) {
    font-family: 'SF Mono', ui-monospace, monospace;
    font-size: 0.9em;
    background: var(--paper-2);
    padding: 2px 6px;
    border-radius: 2px;
  }

  @media (max-width: 760px) {
    .qarticle__body { padding: 48px 20px; }
    .article-content { font-size: 16px; }
    .article-content :global(h2) { font-size: 26px; }
    .article-content :global(h3) { font-size: 20px; }
    .article-content :global(blockquote) { font-size: 19px; padding-left: 20px; }
  }
</style>
