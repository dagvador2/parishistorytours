---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';

// Related posts: same language, exclude current, most recent first, max 3
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.data.lang === post.data.lang && p.id !== post.id)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const canonicalUrl = `https://www.parishistorytours.com${langPrefix}/blog/${post.id}`;
const imageUrl = post.data.image ? `https://www.parishistorytours.com${post.data.image}` : undefined;
---

<BaseLayout
  title={`${post.data.title} | Paris History Tours`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <Breadcrumbs items={[
    { label: t('nav.home'), href: `${langPrefix}/` },
    { label: 'Blog', href: `${langPrefix}/blog` },
    { label: post.data.title }
  ]} />

  <main class="min-h-screen bg-white py-12">
    <article class="max-w-3xl mx-auto px-4">
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt || post.data.title}
          class="w-full h-64 md:h-96 object-cover rounded-xl mb-8"
          loading="eager"
        />
      )}

      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 text-gray-600">
          <span>{post.data.author}</span>
          <span>|</span>
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-gray-100 text-gray-700 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      </header>

      <div class="article-content">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 p-8 bg-gray-50 rounded-xl text-center">
        <h2 class="text-2xl font-bold text-gray-800 mb-3">
          {lang === 'fr' ? 'Envie de découvrir ces lieux en personne ?' : 'Want to discover these places in person?'}
        </h2>
        <p class="text-gray-600 mb-6">
          {lang === 'fr'
            ? 'Rejoignez notre visite guidée de 2 heures à pied dans le Paris de la Seconde Guerre mondiale.'
            : 'Join our 2-hour guided walking tour through WWII Paris.'}
        </p>
        <a href={`${langPrefix}/#book-tour`}
           class="inline-block bg-gray-800 text-white px-8 py-3 rounded-lg hover:bg-gray-700 transition font-medium">
          {t('common.bookNow')}
        </a>
      </div>

      <!-- Author bio -->
      <div class="mt-10 flex items-center gap-5 p-6 bg-gray-50 rounded-xl border border-gray-100">
        <img
          src="/photos/left_bank/Paris_WW2_guide.webp"
          alt="Clément Daguet-Schott"
          width="80"
          height="80"
          class="w-20 h-20 rounded-full object-cover flex-shrink-0"
          loading="lazy"
        />
        <div>
          <p class="font-semibold text-gray-900">Clément Daguet-Schott</p>
          <p class="text-sm text-gray-600 mt-1">
            {lang === 'fr'
              ? 'Passionné d\'histoire et guide indépendant à Paris. Plus de 20 ouvrages de recherche, des visiteurs de 25+ pays et une note de 4.9/5 sur Google.'
              : 'History enthusiast and independent tour guide in Paris. 20+ books of research, visitors from 25+ countries, and a 4.9/5 Google rating.'}
          </p>
          <a href={`${langPrefix}/key-figures`} class="text-sm text-blue-600 hover:text-blue-800 mt-1 inline-block">
            {lang === 'fr' ? 'En savoir plus →' : 'Learn more →'}
          </a>
        </div>
      </div>

      <!-- Related posts -->
      {relatedPosts.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-bold text-gray-900 mb-6">
            {lang === 'fr' ? 'Articles similaires' : 'Related Articles'}
          </h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((related) => (
              <a href={`${langPrefix}/blog/${related.id}`} class="group block rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition">
                {related.data.image && (
                  <img
                    src={related.data.image}
                    alt={related.data.imageAlt || related.data.title}
                    class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                )}
                <div class="p-4">
                  <p class="font-semibold text-gray-900 group-hover:text-blue-700 transition-colors line-clamp-2">
                    {related.data.title}
                  </p>
                  <p class="text-sm text-gray-500 mt-2 line-clamp-2">{related.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "author": {
      "@type": "Person",
      "name": "Clement Daguet-Schott",
      "url": "https://www.parishistorytours.com/key-figures"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Paris History Tours",
      "url": "https://www.parishistorytours.com"
    },
    "datePublished": post.data.publishDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.publishDate).toISOString(),
    "mainEntityOfPage": canonicalUrl,
    ...(imageUrl ? { "image": imageUrl } : {}),
    "inLanguage": post.data.lang
  }} />
</BaseLayout>

<style>
  .article-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #374151;
  }

  .article-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .article-content :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: #1f2937;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-content :global(ul) {
    list-style-type: disc;
  }

  .article-content :global(ol) {
    list-style-type: decimal;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .article-content :global(strong) {
    font-weight: 700;
    color: #111827;
  }

  .article-content :global(em) {
    font-style: italic;
  }

  .article-content :global(a) {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-content :global(a:hover) {
    color: #1d4ed8;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid #d1d5db;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: #f9fafb;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #4b5563;
    font-style: italic;
  }

  .article-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2.5rem 0;
  }
</style>
