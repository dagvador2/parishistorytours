---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

import TopBar from '../../components/quiet/TopBar.astro';
import Nav from '../../components/quiet/Nav.astro';
import MobileBookingBar from '../../components/quiet/MobileBookingBar.astro';
import BlogHeader from '../../components/quiet/BlogHeader.astro';
import BlogList from '../../components/quiet/BlogList.astro';

const lang = Astro.locals.lang;
const t = useTranslations(lang);

const isDefaultLang = lang === 'en';
const langPrefix = isDefaultLang ? '' : '/fr';

const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const sortedPosts = allPosts.sort((a, b) =>
  b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title={t('meta.blog.title')}
  description={t('meta.blog.description')}
  theme="quiet"
>
  <TopBar />
  <Nav context="tour" />

  <main>
    <BlogHeader />
    <BlogList posts={sortedPosts} langPrefix={langPrefix} />
  </main>

  <MobileBookingBar href={`${langPrefix}/#book`} />

  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Paris History Tours Blog",
    "description": t('meta.blog.description'),
    "url": `https://www.parishistorytours.com${langPrefix}/blog`,
    "inLanguage": lang,
    "author": {
      "@type": "Person",
      "name": "Clement Daguet-Schott",
      "url": "https://www.parishistorytours.com/key-figures"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Paris History Tours",
      "url": "https://www.parishistorytours.com"
    }
  }} />
</BaseLayout>

<script>
  import { initQuietNav } from '../../scripts/quiet-nav';
  initQuietNav();
</script>
