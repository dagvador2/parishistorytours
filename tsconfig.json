{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "dist"
  ]
}